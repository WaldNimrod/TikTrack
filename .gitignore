# Log files (data only, not code)
*.log
logs/
.logs/
Backend/logs/

# Backup files (not needed in git)
*.tar.gz
*_backup_*
backup/

# Node modules (if any)
node_modules/
**/node_modules/

# IDE files
.vscode/settings.json
.idea/

# OS files
.DS_Store
Thumbs.db

# Database files (too large for git)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Temporary and cache files
*.tmp
*.temp
*.cache
*.swp
*.swo
*~

# Additional log patterns
*.log.*
logs/*.log.*

# Archive directories (keep local but don't backup)
archive/
reports/advanced-duplicates-*.json
