# TikTrack production and development logs
Backend/logs/*.log
production/Backend/logs/*.log
# Log files (data only, not code)
*.log
logs/
.logs/
Backend/logs/
# Server output log (explicitly excluded - large file)
Backend/server_output.log

# Backup files (not needed in git)
*.tar.gz
*_backup_*
backup/

# Node modules (if any)
node_modules/
**/node_modules/

# IDE files
.vscode/settings.json
.idea/

# OS files
.DS_Store
Thumbs.db

# Database files (too large for git)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Temporary and cache files
*.tmp
*.temp
*.cache
*.swp
*.swo
*~

# Server runtime artifacts (generated on server start/stop)
**/.tiktrack_server_pid
.tiktrack_server_pid

# Additional log patterns
*.log.*
logs/*.log.*

# Bundles (build artifacts - not in git)
trading-ui/scripts/bundles/
*.bundle.js
*.bundle.js.map

# Archive directories (keep local but don't backup)
archive/
reports/advanced-duplicates-*.json

# Production environment - exclude DB and logs only
production/Backend/db/*.db
production/Backend/db/*.db-shm
production/Backend/db/*.db-wal
production/Backend/logs/
production/Backend/logs-production/

Backend/Backend/reports/user_imports/

# Server PID file
Backend/.tiktrack_server_pid

# Test result files
test_results_*.json
*.json.test

# macOS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Python cache
__pycache__/
*.py[cod]
*.class
*.so
.Python

# Temporary test files
/tmp/test_*_results.txt
