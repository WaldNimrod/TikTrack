{
    "version": "2.0.0",
    "tasks": [
        // ========================================
        // 🚀 TikTrack Server Management
        // ========================================
        {
            "label": "TT: Start Server",
            "type": "shell",
            "command": "cd Backend && python3 app.py",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
                "id": "rocket",
                "color": "terminal.ansiGreen"
            }
        },
        {
            "label": "TT: Start Server (Dev Mode)",
            "type": "shell",
            "command": "cd Backend && TIKTRACK_DEV_MODE=true python3 app.py",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
                "id": "beaker",
                "color": "terminal.ansiYellow"
            }
        },
        {
            "label": "TT: Start Server (No Cache)",
            "type": "shell",
            "command": "cd Backend && TIKTRACK_CACHE_DISABLED=true python3 app.py",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
                "id": "debug-disconnect",
                "color": "terminal.ansiRed"
            }
        },
        {
            "label": "TT: Stop Server",
            "type": "shell",
            "command": "lsof -ti :8080 | xargs kill -9 2>/dev/null || true",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
                "id": "debug-stop",
                "color": "terminal.ansiRed"
            }
        },
        {
            "label": "TT: Restart Server",
            "type": "shell",
            "command": "lsof -ti :8080 | xargs kill -9 2>/dev/null || true; sleep 1; cd Backend && python3 app.py",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
                "id": "refresh",
                "color": "terminal.ansiCyan"
            }
        },
        {
            "label": "TT: Clear Cache Full",
            "type": "shell",
            "command": "curl -X POST http://localhost:8080/api/cache/clear && rm -rf trading-ui/.cache 2>/dev/null && rm -rf __pycache__ 2>/dev/null && echo '\n✅ Full cache cleared (server + local files)'",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "showReuseMessage": false,
                "clear": true,
                "revealProblems": "never"
            },
            "problemMatcher": [],
            "icon": {
