/**
 * TikTrack UI Audit Tool - Team 10
 * --------------------------------
 * סקריפט לחילוץ אוטומטי של סגנונות (Computed Styles) ממערכת הלגסי.
 * הוראות: הרץ את הקוד ב-Console של הדפדפן בדף הלגסי.
 */

(function() {
    const report = {
        timestamp: new Date().toISOString(),
        url: window.location.href,
        elements: {}
    };

    // רשימת סלקטורים למיפוי (ניתן להוסיף סלקטורים ספציפיים מהלגסי)
    const selectors = {
        "MainTitle": "h1",
        "SectionHeader": ".section-header, h2, h3",
        "InputField": "input[type='text'], input[type='password'], input[type='tel']",
        "SelectField": "select",
        "PrimaryButton": "button.primary, .btn-save",
        "SectionContainer": "section, .card, .container",
        "Label": "label"
    };

    const propertiesToExtract = [
        "font-family", "font-size", "font-weight", "line-height", "color",
        "background-color", "border-top-color", "border-top-width", "border-radius",
        "padding-top", "padding-right", "padding-bottom", "padding-left",
        "margin-top", "margin-right", "margin-bottom", "margin-left",
        "box-shadow", "height", "display"
    ];

    for (const [key, selector] of Object.entries(selectors)) {
        const el = document.querySelector(selector);
        if (el) {
            const styles = window.getComputedStyle(el);
            report.elements[key] = {
                selector: selector,
                styles: {}
            };
            propertiesToExtract.forEach(prop => {
                report.elements[key].styles[prop] = styles.getPropertyValue(prop);
            });
        }
    }

    console.log("%c 🚀 TikTrack Style Audit Complete!", "color: #26baac; font-weight: bold; font-size: 14px;");
    console.log("Copy the object below and paste it back to the AI:");
    console.log(JSON.stringify(report, null, 2));
    
    // יצירת קובץ להורדה מיידית ליתר ביטחון
    const blob = new Blob([JSON.stringify(report, null, 2)], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `ui_audit_${new Date().getTime()}.json`;
    a.click();
})();
