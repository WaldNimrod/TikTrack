{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SPEC_PACKAGE_SCHEMA_v1.0",
  "title": "Phoenix Spec Package",
  "type": "object",
  "required": [
    "module_id",
    "stage_id",
    "context",
    "scope",
    "requirements",
    "acceptance_criteria",
    "data_contracts",
    "ui_contract",
    "edge_cases",
    "test_plan",
    "dependencies",
    "operational_constraints"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "DRAFT",
            "APPROVED",
            "DEPRECATED"
          ]
        },
        "sv": {
          "type": "string",
          "description": "System version applicability (NOT document schema)."
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "module_id": {
      "type": "string"
    },
    "stage_id": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "MUST",
              "SHOULD",
              "MAY"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "schema"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "schema": {
            "type": "object"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "ui_contract": {
      "type": "object",
      "required": [
        "flows",
        "states",
        "dom_expectations"
      ],
      "properties": {
        "flows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "states": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blueprint_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dom_expectations": {
          "type": "object",
          "properties": {
            "root_selector": {
              "type": "string"
            },
            "required_components": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "required_classes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "css_variables": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "edge_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_plan": {
      "type": "object",
      "required": [
        "unit",
        "integration",
        "e2e"
      ],
      "properties": {
        "unit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "integration": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "e2e": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operational_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
