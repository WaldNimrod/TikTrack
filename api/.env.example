# TikTrack Phoenix - Backend Environment Variables Template
# ==========================================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to git (already in .gitignore)

# Database Configuration
# Format: postgresql://username:password@host:port/database
# For Docker container: postgresql://postgres:password@localhost:5432/tiktrack
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/tiktrack

# JWT Configuration
# Must be at least 64 characters long
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
JWT_SECRET_KEY=your-generated-64-character-secret-key-here-minimum-64-chars-long

# Encryption Key (Optional but recommended)
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
ENCRYPTION_KEY=your-generated-32-character-encryption-key-here

# CORS Configuration (Optional - defaults to localhost:8080)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# External Market Data (Optional - Yahoo works without; Alpha Primary for FX)
# Free key: https://www.alphavantage.co/support/#api-key (5 calls/min)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Rate-Limit & Scaling (TEAM_90_RATELIMIT_SCALING_LOCK) — Optional, defaults below
# MAX_ACTIVE_TICKERS=50
# INTRADAY_INTERVAL_MINUTES=15
# PROVIDER_COOLDOWN_MINUTES=15
# MAX_SYMBOLS_PER_REQUEST=5
