<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
            <!-- ===== CSS Architecture - Unified CSS ===== -->
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Framework -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- TikTrack CSS - ITCSS Main Import File -->
    <link rel="stylesheet" href="styles-new/main.css">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Header Styles - Separate CSS file (Exception to unified CSS system) -->
    <link rel="stylesheet" href="styles-new/header-styles.css?v=20250115_level3_fix">
    
    <!-- JS-Map Advanced Styles -->
    <link rel="stylesheet" href="styles-new/07-trumps/js-map-advanced.css">
    

    <!-- Core scripts - Required order -->
    <script src="scripts/header-system.js"></script>
    <script src="scripts/color-scheme-system.js"></script>
    <script src="scripts/preferences.js"></script>
    <script src="scripts/ui-utils.js"></script>
    <script src="scripts/js-map-indexeddb-adapter.js"></script>
</head>

<body>
    <!-- Unified Header Container -->
    <div id="unified-header"></div>

    <!-- Page Body -->
    <div class="page-body">
        <!-- Main content limited in width -->
        <div class="main-content">
            <!-- Top Section - לפי מפרט המערכת -->
            <div class="top-section">
                <div class="section-header">
                    <h2>🗺️ מפת JavaScript - כלי פיתוח מתקדם</h2>
                    <div class="header-actions">
                        <button class="action-btn copy-log-btn" onclick="copyDetailedLog()" title="העתק לוג מפורט של כל הממשקים">
                            <i class="fas fa-copy"></i> העתק לוג מפורט
                        </button>
                        <button class="filter-toggle-btn" onclick="toggleTopSection()" title="הצג/הסתר סקשן">
                            <span class="section-toggle-icon">▼</span>
                        </button>
                    </div>
                </div>
                <div class="section-body">
                    <!-- סטטיסטיקות מערכת -->
                    <div class="system-stats">
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon">📄</div>
                                <div class="stat-value" id="totalPagesCount">-</div>
                                <div class="stat-label">עמודי HTML</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon">📜</div>
                                <div class="stat-value" id="totalJsFilesCount">-</div>
                                <div class="stat-label">קבצי JS</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon">⚙️</div>
                                <div class="stat-value" id="totalFunctionsCount">-</div>
                                <div class="stat-label">פונקציות</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon">🌍</div>
                                <div class="stat-value" id="globalFunctionsCount">-</div>
                                <div class="stat-label">פונקציות גלובליות</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon">🔍</div>
                                <div class="stat-value" id="duplicatesCount">-</div>
                                <div class="stat-label">כפילויות זוהו</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon">🏠</div>
                                <div class="stat-value" id="localFunctionsCount">-</div>
                                <div class="stat-label">פונקציות מקומיות</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- חיפוש מהיר -->
                    <div class="quick-search">
                        <div class="search-box">
                            <input type="text" id="quickSearch" placeholder="חיפוש מהיר בפונקציות..." onkeyup="performQuickSearch(this.value)">
                            <button onclick="performQuickSearch(document.getElementById('quickSearch').value)">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <div id="quickSearchResults" class="search-results"></div>
                    </div>
                    
                    <!-- כפתורי פעולה מהירה -->
                    <div class="quick-actions">
                        <button class="action-btn" onclick="refreshAllData()" title="רענן את כל הנתונים">
                            <i class="fas fa-sync-alt"></i> רענן נתונים
                        </button>
                        <button class="action-btn" onclick="exportToCSV()" title="ייצוא ל-CSV">
                            <i class="fas fa-file-csv"></i> ייצוא CSV
                        </button>
                        <button class="action-btn" onclick="exportToJSON()" title="ייצוא ל-JSON">
                            <i class="fas fa-file-code"></i> ייצוא JSON
                        </button>
                        <button class="action-btn" onclick="generateReport()" title="יצירת דוח מפורט">
                            <i class="fas fa-file-alt"></i> יצירת דוח
                        </button>
                    </div>
                    
                    <!-- Functions Dropdown -->
                    <div class="functions-dropdown-container">
                        <button class="dropdown-toggle" onclick="toggleFunctionsDropdown()">
                            <i class="fas fa-search"></i> חיפוש פונקציות מתקדם
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div id="functionsDropdown" class="functions-dropdown">
                            <div id="functionsDropdownContent" class="functions-dropdown-content">
                                <div class="loading">טוען פונקציות...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- UI Content Section Top End -->

            <!-- UI Content Section 1 Start-->
            <div class="content-section" id="section1">
                <div class="section-header">
                    <h2>🗺️ מיפוי עמודים לקבצים JS</h2>
                    <button class="filter-toggle-btn" onclick="toggleSection('section1')" title="הצג/הסתר סקשן">
                        <span class="section-toggle-icon">▼</span>
                    </button>
                </div>
                <div class="section-body">
                <div id="pageMappingContent">
                    <div class="loading">
                        <div class="loading-spinner"></div>
                        טוען מיפוי עמודים...
                    </div>
                </div>
            </div>
            </div>
            <!-- UI Content Section 1 End -->

            <!-- UI Content Section 2 - ניתוח כפילויות (לפי מפרט) -->
            <div class="content-section" id="section2">
                <div class="section-header">
                    <h2>🔍 ניתוח פונקציות כפולות ודומות</h2>
                    <button class="filter-toggle-btn" onclick="toggleSection('section2')" title="הצג/הסתר סקשן">
                        <span class="section-toggle-icon">▼</span>
                    </button>
                </div>
                <div class="section-body">
                    <div id="duplicatesContent">
                        <div class="loading">
                            <div class="loading-spinner"></div>
                            <p>טוען ניתוח כפילויות...</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- UI Content Section 2 End -->

            <!-- UI Content Section 2.1 - פונקציות מפורטות (תת-סקשן של מיפוי) -->
            <div class="content-section" id="section2-1">
                <div class="section-header">
                    <h2>⚙️ פונקציות מפורטות</h2>
                    <button class="filter-toggle-btn" onclick="toggleSection('section2-1')" title="הצג/הסתר סקשן">
                        <span class="section-toggle-icon">▼</span>
                    </button>
                </div>
                <div class="section-body">
                <div id="functionsContent">
                    <div class="loading">
                        <div class="loading-spinner"></div>
                        טוען פונקציות...
                    </div>
                </div>
            </div>
            </div>
            <!-- UI Content Section 2.1 End -->
        </div>
    </div>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTopBtn" onclick="scrollToTop()" title="חזור לראש העמוד">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- Function Modal -->
    <div id="functionModal" class="function-modal">
        <div class="function-modal-content">
            <div class="function-modal-header">
                <h3 class="function-modal-title" id="modalFunctionName"></h3>
                <button class="function-modal-close" onclick="closeFunctionModal()">&times;</button>
            </div>
            <div class="function-modal-body">
                <div class="function-annotations" id="modalAnnotations"></div>
                <div class="function-code" id="modalCode"></div>
            </div>
        </div>
    </div>


    <!-- UI Content Section 3 - זיהוי פונקציות מקומיות -->
    <div class="content-section" id="section3">
        <div class="section-header">
            <h2>🏠 זיהוי פונקציות מקומיות</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section3')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="localFunctionsContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>טוען זיהוי פונקציות מקומיות...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- UI Content Section 4 - ניתוח תלויות -->
    <div class="content-section" id="section4">
        <div class="section-header">
            <h2>🔗 ניתוח תלויות בין קבצים</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section4')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="dependenciesContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>טוען ניתוח תלויות...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- UI Content Section 5 - סטטיסטיקות מערכת -->
    <div class="content-section" id="section5">
        <div class="section-header">
            <h2>📊 סטטיסטיקות מערכת</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section5')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="statisticsContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>טוען סטטיסטיקות...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- UI Content Section 6 - ניהול אחסון נתונים -->
    <div class="content-section" id="section6">
        <div class="section-header">
            <h2>💾 ניהול אחסון נתונים</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section6')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="storageContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>טוען ניהול אחסון...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- UI Content Section 7 - בדיקת ארכיטקטורה (לפי מפרט) -->
    <div class="content-section" id="section7">
        <div class="section-header">
            <h2>🏗️ בדיקת ארכיטקטורה</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section7')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="architectureContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>טוען בדיקת ארכיטקטורה...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- UI Content Section 8 - סטטוס אינטגרציה עם מערכת סריקת קבצים -->
    <div class="content-section" id="section8">
        <div class="section-header">
            <h2>🔗 סטטוס אינטגרציה עם מערכת סריקת קבצים</h2>
            <button class="filter-toggle-btn" onclick="toggleSection('section8')" title="הצג/הסתר סקשן">
                <span class="section-toggle-icon">▼</span>
            </button>
        </div>
        <div class="section-body">
            <div id="integrationContent">
                <div class="loading">
                    <div class="loading-spinner"></div>
                    <p>בודק סטטוס אינטגרציה...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Function Calls Modal -->
    <div id="functionCallsModal" class="function-modal">
        <div class="function-modal-content">
            <div class="function-modal-header">
                <h3 class="function-modal-title" id="modalFunctionCallsTitle"></h3>
                <button class="function-modal-close" onclick="closeFunctionCallsModal()">&times;</button>
            </div>
            <div class="function-modal-body">
                <div id="functionCallsContent"></div>
            </div>
        </div>
    </div>

    <!-- Core System Scripts - Required order -->
    <script src="scripts/table-mappings.js"></script>
    <script src="scripts/date-utils.js"></script>
    <script src="scripts/tables.js"></script>
    <script src="scripts/page-utils.js"></script>
    <script src="scripts/main.js"></script>
    <script src="scripts/console-cleanup.js"></script>
    <script src="scripts/translation-utils.js"></script>
    <script src="scripts/data-utils.js"></script>
    <script src="scripts/linked-items.js"></script>

    <!-- Page Scripts -->
    <script src="scripts/js-map.js"></script>


</body>
</html>
