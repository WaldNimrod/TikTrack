# Main execution
main() {
    local mode="quick"
    local interactive=false
    local verbose=false
    local cache_mode="preserve"  # Default: preserve current state
    
    # Show troubleshooting note for quick mode
    if [ "$1" = "" ] || [ "$1" = "quick" ] || [ "$1" = "--quick" ]; then
        echo ""
        echo "⚠️  TROUBLESHOOTING NOTE:"
        echo "========================="
        echo "If quick restart doesn't resolve your issue, run:"
        echo "  ./restart complete    # For comprehensive restart"
        echo "  ./restart --interactive  # For guided troubleshooting"
        echo ""
    fi
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            quick|--quick)
                mode="quick"
                shift
                ;;
            complete|--complete)
                mode="complete"
                shift
                ;;
            auto|--auto)
                mode="auto"
                shift
                ;;
            --cache-mode=*)
                cache_mode="${1#*=}"
                shift
                ;;
            --preserve-cache)
                cache_mode="preserve"
                shift
                ;;
            -i|--interactive)
                interactive=true
                shift
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --info)
                show_mode_info
                exit 0
                ;;
            --status)
                check_system_status
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Set global variables
    VERBOSE="$verbose"
    
    # Set cache environment based on user choice
    log_info "Setting cache mode: $cache_mode"
    set_cache_environment "$cache_mode"
    
    # Header
    echo "🔄 TikTrack Unified Server Restart Script"
    echo "=========================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Mode: $mode"
    echo "🧠 Cache: $cache_mode"
    echo ""
    
    # Check if scripts exist
    if [ ! -f "$QUICK_SCRIPT" ]; then
        log_error "Quick restart script not found: $QUICK_SCRIPT"
        exit 1
    fi
    
    if [ ! -f "$COMPLETE_SCRIPT" ]; then
        log_error "Complete restart script not found: $COMPLETE_SCRIPT"
        exit 1
    fi
    
    # Interactive mode
    if [ "$interactive" = "true" ]; then
        show_interactive_choice
        exit 0
    fi
    
    # Determine restart mode
    if [ "$mode" = "auto" ]; then
        log_info "🔍 Auto-detecting optimal restart mode..."
        # Call detection function and capture result
        detected_mode=$(detect_optimal_mode | tail -1)
        mode="$detected_mode"
        log_info "Selected mode: $mode"
    elif [ "$mode" = "quick" ]; then
        log_info "⚡ Using quick restart mode (default)"
    fi
    
    # Execute restart
    case $mode in
        quick)
            run_quick_restart
            ;;
        complete)
            run_complete_restart
            ;;
        *)
            log_error "Invalid mode: $mode"
            exit 1
            ;;
    esac
    
    # Final status
    if [ $? -eq 0 ]; then
        log_success "✅ Server restart completed successfully"
        echo ""
        echo "🎉 Restart completed!"
        echo "🌐 Server should be available at: http://localhost:8080"
        echo ""
        
        # Show cache state after restart
        echo "🧠 Cache State After Restart:"
        echo "=============================="
        case $cache_mode in
            development)
                echo "   Mode: DEVELOPMENT (10 seconds TTL)"
                ;;
            no-cache)
                echo "   Mode: NO-CACHE (disabled)"
                ;;
            production)
                echo "   Mode: PRODUCTION (5 minutes TTL)"
                ;;
            preserve)
                echo "   Mode: PRESERVED (current state maintained)"
                ;;
        esac
        echo ""
        
        # Show additional help if this was a quick restart
        if [ "$mode" = "quick" ]; then
            echo "💡 If you experience issues, consider complete restart:"
            echo "   $0 complete"
            echo ""
        fi
    else
        log_error "❌ Server restart failed"
        echo ""
        echo "💡 TROUBLESHOOTING REQUIRED:"
        echo "============================="
        echo ""
        echo "Quick restart failed. Try these solutions in order:"
        echo ""
        echo "1️⃣  COMPLETE RESTART (Recommended):"
        echo "   $0 complete"
        echo ""
        echo "2️⃣  INTERACTIVE MODE (Guided troubleshooting):"
        echo "   $0 --interactive"
        echo ""
        echo "3️⃣  VERBOSE DIAGNOSTICS:"
        echo "   $0 --verbose complete"
        echo ""
        echo "4️⃣  CHECK LOGS:"
        echo "   tail -f $DETAILED_LOG"
        echo ""
        echo "The complete mode performs comprehensive system analysis"
        echo "and automatic problem fixing that the quick mode doesn't include."
        echo ""
        exit 1
    fi
}

# Run main function
main "$@"
