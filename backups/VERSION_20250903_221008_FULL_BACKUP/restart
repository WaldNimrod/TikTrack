#   ./restart --cache-mode=development    # Quick + development cache
#   ./restart --cache-mode=no-cache       # Quick + no-cache
#   ./restart --cache-mode=production     # Quick + production cache
# 
# Interactive mode:
#   ./restart --interactive     # Ask user for choice
