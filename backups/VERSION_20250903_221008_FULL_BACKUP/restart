# Function to detect optimal restart mode
detect_optimal_mode() {
    log_info "🔍 Detecting optimal restart mode..."
    
    # Check system resources
    local memory_usage=$(free | grep Mem | awk '{printf "%.0f", $3/$2 * 100.0}')
    local disk_usage=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    
    log_info "Memory usage: ${memory_usage}%"
    log_info "Disk usage: ${disk_usage}%"
    
    # Check for recent errors
    local recent_errors=$(grep -c "ERROR\|CRITICAL" logs/server_detailed.log 2>/dev/null || echo "0")
    log_info "Recent errors in logs: $recent_errors"
    
    # Decision logic
    if [ "$memory_usage" -gt 90 ] || [ "$disk_usage" -gt 90 ] || [ "$recent_errors" -gt 10 ]; then
        log_info "System indicators suggest COMPLETE mode"
        echo "complete"
    else
        log_info "System indicators suggest QUICK mode"
        echo "quick"
    fi
}

# Function to run quick restart
run_quick_restart() {
    log_info "⚡ Running quick restart mode..."
    
    if [ ! -f "$QUICK_SCRIPT" ]; then
        log_error "Quick restart script not found: $QUICK_SCRIPT"
        return 1
    fi
    
    # Pass cache environment variables to quick script
    export TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE"
    export TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED"
    
    if [ "$VERBOSE" = "true" ]; then
        bash "$QUICK_SCRIPT"
    else
        bash "$QUICK_SCRIPT" > /dev/null 2>&1
    fi
    
    if [ $? -eq 0 ]; then
        log_success "Quick restart completed successfully"
        return 0
    else
        log_error "Quick restart failed"
        return 1
    fi
}

