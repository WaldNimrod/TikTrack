.status-cancelled-text {
  color: var(--status-cancelled-color);
}

/* סטטוס ממתין - Pending */
.status-pending {
  color: var(--status-pending-color);
  background-color: color-mix(in srgb, var(--status-pending-color) 10%, transparent);
}

