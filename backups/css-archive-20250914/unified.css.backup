  color: var(--status-closed-color);
  background-color: color-mix(in srgb, var(--status-closed-color) 10%, transparent);
}

.status-closed-bg {
  background-color: color-mix(in srgb, var(--status-closed-color) 10%, transparent);
}

.status-closed-text {
  color: var(--status-closed-color);
}

/* סטטוס מבוטל - Cancelled */
