}

/* סטטוס פעיל - Active */
.status-active {
  color: var(--status-active-color);
  background-color: color-mix(in srgb, var(--status-active-color) 10%, transparent);
}

.status-active-bg {
  background-color: color-mix(in srgb, var(--status-active-color) 10%, transparent);
