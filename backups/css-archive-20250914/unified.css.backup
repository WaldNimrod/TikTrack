.status-active-text {
  color: var(--status-active-color);
}

/* סטטוס לא פעיל - Inactive */
.status-inactive {
  color: var(--status-inactive-color);
  background-color: color-mix(in srgb, var(--status-inactive-color) 10%, transparent);
}

