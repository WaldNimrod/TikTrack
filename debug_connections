#!/bin/bash

# TikTrack Connection Debug Script
# =================================
# 
# 🎯 Purpose: Debug server connections and hanging issues
# 🔍 Features: Detailed logging, connection monitoring, process tracking
# 📊 Focus: Active connections, hanging processes, server state

set -e

# Configuration
SERVER_PORT=8080
SERVER_HOST="127.0.0.1"
DEBUG_INTERVAL=2  # Check every 2 seconds
MAX_DEBUG_TIME=30  # Debug for max 30 seconds

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Timestamp
timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Logging
log_info() {
    echo -e "${BLUE}[$(timestamp)] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(timestamp)] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(timestamp)] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(timestamp)] ERROR:${NC} $1"
}

log_debug() {
    echo -e "${CYAN}[$(timestamp)] DEBUG:${NC} $1"
}

# Function to check active connections
check_active_connections() {
    log_debug "🔍 Checking active connections..."
    
    # Check processes using port 8080
    local port_processes=$(lsof -ti:$SERVER_PORT 2>/dev/null || true)
    if [ -n "$port_processes" ]; then
        log_info "Port $SERVER_PORT processes: $port_processes"
        
        # Get detailed process info
        for pid in $port_processes; do
            local process_info=$(ps -p $pid -o pid,ppid,command 2>/dev/null || true)
            if [ -n "$process_info" ]; then
                log_debug "Process $pid details: $process_info"
            fi
        done
    else
        log_info "No processes using port $SERVER_PORT"
    fi
    
    # Check all Python processes
    local python_processes=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep || true)
    if [ -n "$python_processes" ]; then
        log_info "Python processes found:"
        echo "$python_processes" | while read line; do
            log_debug "  $line"
        done
    else
        log_info "No Python processes found"
    fi
    
    # Check network connections
    local network_connections=$(netstat -an | grep ":$SERVER_PORT" || true)
    if [ -n "$network_connections" ]; then
        log_info "Network connections on port $SERVER_PORT:"
        echo "$network_connections" | while read line; do
            log_debug "  $line"
        done
    else
        log_info "No network connections on port $SERVER_PORT"
    fi
}

# Function to test server response
test_server_response() {
    log_debug "🌐 Testing server response..."
    
    # Test basic HTTP response
    local http_response=$(curl -s -w "HTTP_CODE:%{http_code},TIME:%{time_total}" --max-time 5 "http://$SERVER_HOST:$SERVER_PORT/" 2>/dev/null || true)
    if [ -n "$http_response" ]; then
        log_success "HTTP response received: $http_response"
        return 0
    else
        log_warning "No HTTP response received"
        return 1
    fi
}

# Function to test API endpoints
test_api_endpoints() {
    log_debug "🔌 Testing API endpoints..."
    
    local endpoints=("/api/health" "/api/server/current-mode" "/api/cache/stats")
    
    for endpoint in "${endpoints[@]}"; do
        local api_response=$(curl -s -w "HTTP_CODE:%{http_code},TIME:%{time_total}" --max-time 3 "http://$SERVER_HOST:$SERVER_PORT$endpoint" 2>/dev/null || true)
        if [ -n "$api_response" ]; then
            log_success "API $endpoint: $api_response"
        else
            log_warning "API $endpoint: No response"
        fi
    done
}

# Function to monitor server startup
monitor_server_startup() {
    log_info "📊 Starting server startup monitoring..."
    
    local attempts=0
    local max_attempts=$((MAX_DEBUG_TIME / DEBUG_INTERVAL))
    local server_ready=false
    
    while [ $attempts -lt $max_attempts ]; do
        attempts=$((attempts + 1))
        local elapsed_time=$((attempts * DEBUG_INTERVAL))
        
        log_info "=== Monitoring attempt $attempts/$max_attempts (${elapsed_time}s elapsed) ==="
        
        # Check active connections
        check_active_connections
        echo ""
        
        # Test server response
        if test_server_response; then
            log_success "✅ Server is responding to HTTP requests"
            
            # Test API endpoints
            test_api_endpoints
            echo ""
            
            server_ready=true
            break
        else
            log_warning "⚠️ Server not responding to HTTP requests"
        fi
        
        echo ""
        
        if [ $attempts -lt $max_attempts ]; then
            log_info "Waiting ${DEBUG_INTERVAL} seconds before next check..."
            sleep $DEBUG_INTERVAL
        fi
    done
    
    if [ "$server_ready" = true ]; then
        log_success "🎉 Server is fully ready after ${elapsed_time} seconds"
        return 0
    else
        log_warning "⚠️ Server monitoring timeout after ${MAX_DEBUG_TIME} seconds"
        return 1
    fi
}

# Function to start server for testing
start_server_for_testing() {
    log_info "🚀 Starting server for testing..."
    
    # Check if Backend directory exists
    if [ ! -d "Backend" ]; then
        log_error "Backend directory not found"
        return 1
    fi
    
    # Enter Backend directory
    cd Backend
    
    # Start server with environment variables
    TIKTRACK_DEV_MODE="true" \
    TIKTRACK_CACHE_DISABLED="false" \
    nohup python3 dev_server.py > /dev/null 2>&1 &
    
    local server_pid=$!
    cd ..
    
    log_success "Server process started with PID: $server_pid"
    return 0
}

# Function to stop server
stop_server() {
    log_info "🛑 Stopping server..."
    
    # Stop Python processes
    local python_processes=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep | awk '{print $2}')
    
    if [ -n "$python_processes" ]; then
        log_info "Found Python processes: $python_processes"
        echo "$python_processes" | xargs kill -TERM 2>/dev/null || true
        sleep 3
        
        # Check if processes still exist
        local remaining=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep | awk '{print $2}')
        if [ -n "$remaining" ]; then
            log_warning "Force killing remaining processes: $remaining"
            echo "$remaining" | xargs kill -KILL 2>/dev/null || true
        fi
    else
        log_info "No existing Python processes found"
    fi
    
    # Kill processes using port 8080
    local port_processes=$(lsof -ti:8080 2>/dev/null || true)
    if [ -n "$port_processes" ]; then
        log_warning "Killing processes using port 8080: $port_processes"
        echo "$port_processes" | xargs kill -TERM 2>/dev/null || true
        sleep 2
    fi
    
    log_success "Server cleanup completed"
}

# Main function
main() {
    echo "🔍 TikTrack Connection Debug Script"
    echo "===================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Purpose: Debug server connections and hanging issues"
    echo "⏱️ Max Debug Time: ${MAX_DEBUG_TIME}s"
    echo "🔍 Check Interval: ${DEBUG_INTERVAL}s"
    echo ""
    
    # Stop any existing server
    stop_server
    echo ""
    
    # Start server for testing
    if start_server_for_testing; then
        echo ""
        
        # Monitor server startup
        if monitor_server_startup; then
            echo ""
            log_success "🎉 Debug completed successfully!"
            echo "📊 Summary:"
            echo "   - Server started successfully"
            echo "   - All connections working"
            echo "   - No hanging issues detected"
            echo ""
        else
            echo ""
            log_warning "⚠️ Debug completed with issues"
            echo "📊 Summary:"
            echo "   - Server may have startup issues"
            echo "   - Some connections may be hanging"
            echo "   - Check logs for details"
            echo ""
        fi
    else
        log_error "❌ Failed to start server for testing"
        exit 1
    fi
    
    # Final connection check
    log_info "🔍 Final connection check..."
    check_active_connections
    echo ""
    
    log_info "✅ Debug script completed - control returned"
    exit 0
}

# Run main function
main "$@"
