{
    "source": {
        "include": [
            "trading-ui/scripts/",
            "documentation/03-API_REFERENCE/",
            "README.md"
        ],
        "includePattern": "\\.(js|md)$",
        "excludePattern": "(node_modules/|backup/|archive/|_Tmp/)"
    },
    "opts": {
        "destination": "documentation/07-GENERATED/",
        "recurse": true,
        "readme": "README.md",
        "template": "node_modules/docdash"
    },
    "plugins": [
        "plugins/markdown",
        "plugins/summarize"
    ],
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false,
        "default": {
            "outputSourceFiles": true,
            "outputSourcePath": true,
            "useLongnameInNav": true,
            "includeDate": true
        }
    },
    "markdown": {
        "hardwrap": true,
        "gfm": true,
        "tables": true
    },
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": [
            "jsdoc",
            "closure"
        ]
    },
    "sourceType": "module",
    "docdash": {
        "static": true,
        "sort": true,
        "search": true,
        "collapse": false,
        "wrap": true,
        "typedefs": true,
        "navLevel": 1,
        "private": false,
        "removeQuotes": "trim",
        "menu": {
            "TikTrack API": {
                "href": "https://github.com/WaldNimrod/TikTrack",
                "class": "menu-item",
                "id": "home-link"
            }
        }
    }
}
