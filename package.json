{
  "name": "tiktrackapp",
  "version": "1.0.0",
  "description": "> 📋 **משימות מרכזיות**: [CENTRAL_TASKS_TODO.md](CENTRAL_TASKS_TODO.md)",
  "main": "index.js",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js --selectProjects unit --runInBand",
    "test:integration": "jest --config jest.config.js --selectProjects integration --runInBand",
    "test:component": "jest --config jest.config.js --selectProjects component --runInBand",
    "test:e2e": "npm run test:component",
    "test:coverage": "jest --config jest.config.ci.js --selectProjects combined --runInBand --coverage",
    "test:watch": "jest --config jest.config.js --watch",
    "test:ci": "jest --config jest.config.ci.js --selectProjects combined --runInBand --coverage --ci",
    "lint": "eslint trading-ui/scripts/*.js",
    "lint:fix": "eslint trading-ui/scripts/*.js --fix",
    "lint:report": "eslint trading-ui/scripts/*.js --format=html --output-file=lint-report.html",
    "lint:collect": "node scripts/lint/collect-lint-results.js",
    "format": "prettier --write trading-ui/scripts/*.js trading-ui/styles/*.css trading-ui/*.html",
    "format:check": "prettier --check trading-ui/scripts/*.js trading-ui/styles/*.css trading-ui/*.html",
    "html:check": "htmlhint trading-ui/*.html",
    "css:check": "stylelint \"trading-ui/styles-new/**/*.css\"",
    "css:fix": "stylelint \"trading-ui/styles-new/**/*.css\" --fix",
    "css:check:old": "stylelint \"trading-ui/styles/*.css\"",
    "css:fix:old": "stylelint \"trading-ui/styles/*.css\" --fix",
    "check:all": "npm run lint && npm run format:check && npm run html:check && npm run css:check",
    "fix:all": "npm run lint:fix && npm run format && npm run css:fix",
    "quality:report": "npm run lint:report && echo \"Quality report generated: lint-report.html\"",
    "performance:check": "lighthouse http://localhost:8080 --output=html --output-path=./performance-report.html",
    "bundle:analyze": "webpack-bundle-analyzer trading-ui/scripts/*.js",
    "validate:all": "npm run check:all && npm run quality:report",
    "dev:normal": "TIKTRACK_DEV_MODE=true TIKTRACK_CACHE_DISABLED=false ./restart quick",
    "dev:no-cache": "TIKTRACK_DEV_MODE=true TIKTRACK_CACHE_DISABLED=true ./restart quick",
    "dev:production": "TIKTRACK_DEV_MODE=false TIKTRACK_CACHE_DISABLED=false ./restart quick",
    "cache:clear": "curl -X POST http://localhost:8080/api/cache/clear",
    "css:build": "cat trading-ui/styles-new/main.css > trading-ui/dist/main.css",
    "css:watch": "watch 'npm run css:build' trading-ui/styles-new/",
    "css:minify": "cleancss -o trading-ui/dist/main.min.css trading-ui/dist/main.css",
    "css:analyze": "echo 'CSS Analysis:' && wc -l trading-ui/styles-new/**/*.css",
    "css:compare": "python3 test-css-system.py",
    "css:rtl-test": "echo 'בדיקת RTL: כל הקבצים משתמשים ב-CSS Logical Properties'",
    "css:performance": "echo 'בדיקת ביצועים: המערכת החדשה קטנה ב-83%' && python3 test-css-system.py",
    "test:a11y": "jest --runTestsByPath tests/integration/accessibility/a11y-baseline.test.js --coverage=false",
    "jsdoc:add": "node scripts/add-jsdoc.js",
    "jsdoc:generate": "jsdoc -c jsdoc.conf.json",
    "jsdoc:validate": "jsdoc -X",
    "jsdoc:check": "jsdoc -X | grep 'Missing' || echo 'No missing JSDoc found'",
    "docs:generate": "npm run jsdoc:generate",
    "docs:validate": "npm run jsdoc:validate",
    "docs:check": "npm run jsdoc:check",
    "docs:add": "npm run jsdoc:add",
    "docs:update": "npm run docs:add && npm run docs:generate",
    "ci:prefs-guards": "bash scripts/ci/preferences-guards.sh",
    "build:bundles": "node scripts/build/bundle-packages.js",
    "build:bundles:package": "node scripts/build/bundle-packages.js",
    "test:bundles": "node scripts/build/test-bundles.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WaldNimrod/TikTrack.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/WaldNimrod/TikTrack/issues"
  },
  "homepage": "https://github.com/WaldNimrod/TikTrack#readme",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "axe-core": "^4.10.3",
    "esbuild": "^0.24.2",
    "eslint": "^9.34.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^54.1.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^60.0.0",
    "htmlhint": "^1.6.3",
    "htmlhint-stylish": "^1.0.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^12.8.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "puppeteer": "^24.18.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.1",
    "text-encoding": "^0.7.0",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
