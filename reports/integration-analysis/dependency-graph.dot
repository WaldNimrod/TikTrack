digraph TikTrackIntegration {
    rankdir=LR;
    node [shape=box, style=rounded];

    subgraph cluster_Service {
        label="Service";
        style=dashed;

        AlertConditionRenderer[label="AlertConditionRenderer"];
        CRUDResponseHandler[label="CRUDResponseHandler"];
        DataCollectionService[label="DataCollectionService"];
        DefaultValueSetter[label="DefaultValueSetter"];
        FieldRendererService[label="FieldRendererService"];
        LinkedItemsService[label="LinkedItemsService"];
        SelectPopulatorService[label="SelectPopulatorService"];
        StatisticsCalculator[label="StatisticsCalculator"];
    }

    subgraph cluster_System {
        label="System";
        style=dashed;

        ActionsMenuSystem[label="ActionsMenuSystem"];
        UnifiedAppInitializer[label="UnifiedAppInitializer"];
        NotificationSystem[label="NotificationSystem"];
        Logger[label="Logger"];
        HeaderSystem[label="HeaderSystem"];
        ButtonSystem[label="ButtonSystem"];
        ColorSchemeSystem[label="ColorSchemeSystem"];
        InfoSummarySystem[label="InfoSummarySystem"];
        PreferencesCore[label="PreferencesCore"];
    }

    subgraph cluster_Function {
        label="Function";
        style=dashed;

        loadTableData[label="loadTableData"];
        showFieldError[label="showFieldError"];
    }

    subgraph cluster_Manager {
        label="Manager";
        style=dashed;

        ModalManagerV2[label="ModalManagerV2"];
        UnifiedCacheManager[label="UnifiedCacheManager"];
        CacheSyncManager[label="CacheSyncManager"];
        CachePolicyManager[label="CachePolicyManager"];
        ModalNavigationManager[label="ModalNavigationManager"];
        EventHandlerManager[label="EventHandlerManager"];
        PreferencesGroupManager[label="PreferencesGroupManager"];
    }

    subgraph cluster_EntityService {
        label="EntityService";
        style=dashed;

        AlertService[label="AlertService"];
        TickerService[label="TickerService"];
        TradePlanService[label="TradePlanService"];
        AccountService[label="AccountService"];
    }

    subgraph cluster_Modal {
        label="Modal";
        style=dashed;

        EntityDetailsModal[label="EntityDetailsModal"];
    }

    subgraph cluster_Renderer {
        label="Renderer";
        style=dashed;

        EntityDetailsRenderer[label="EntityDetailsRenderer"];
    }

    subgraph cluster_API {
        label="API";
        style=dashed;

        EntityDetailsAPI[label="EntityDetailsAPI"];
    }

    subgraph cluster_Utility {
        label="Utility";
        style=dashed;

        toggleSection[label="toggleSection"];
    }

    CRUDResponseHandler -> UnifiedCacheManager;
    LinkedItemsService -> ModalManagerV2;
    SelectPopulatorService -> PreferencesCore;
    SelectPopulatorService -> PreferencesSystem;
    loadTableData -> CRUDResponseHandler;
    loadTableData -> ModalManagerV2;
    loadTableData -> toggleSection;
    UnifiedAppInitializer -> UnifiedCacheManager;
    UnifiedAppInitializer -> PreferencesSystem;
    UnifiedAppInitializer -> Logger;
    UnifiedAppInitializer -> NotificationSystem;
    UnifiedAppInitializer -> ActionsMenuSystem;
    UnifiedAppInitializer -> HeaderSystem;
    UnifiedAppInitializer -> toggleSection;
    ModalManagerV2 -> PreferencesSystem;
    ModalManagerV2 -> SelectPopulatorService;
    UnifiedCacheManager -> Logger;
    UnifiedCacheManager -> CacheSyncManager;
    UnifiedCacheManager -> PreferencesCore;
    CacheSyncManager -> Logger;
    ModalNavigationManager -> Logger;
    ModalNavigationManager -> UnifiedCacheManager;
    ModalNavigationManager -> ButtonSystem;
    EventHandlerManager -> Logger;
    EventHandlerManager -> ModalManagerV2;
    EventHandlerManager -> toggleSection;
    NotificationSystem -> Logger;
    NotificationSystem -> UnifiedCacheManager;
    Logger -> toggleSection;
    HeaderSystem -> Logger;
    HeaderSystem -> UnifiedCacheManager;
    ButtonSystem -> Logger;
    ColorSchemeSystem -> Logger;
    InfoSummarySystem -> Logger;
    AlertService -> Logger;
    TickerService -> Logger;
    PreferencesGroupManager -> PreferencesCore;
    PreferencesGroupManager -> UnifiedCacheManager;
    EntityDetailsModal -> Logger;
    EntityDetailsRenderer -> Logger;
    EntityDetailsRenderer -> FieldRendererService;
    EntityDetailsRenderer -> LinkedItemsService;
    EntityDetailsRenderer -> ModalManagerV2;
    EntityDetailsAPI -> Logger;
    EntityDetailsAPI -> UnifiedCacheManager;
    toggleSection -> Logger;
    toggleSection -> InfoSummarySystem;
    PreferencesCore -> Logger;
    PreferencesCore -> UnifiedCacheManager;

    // Circular dependencies
    Logger -> Logger [color=red, style=bold];
    Logger -> toggleSection [color=red, style=bold];
    Logger -> toggleSection [color=red, style=bold];
    toggleSection -> Logger [color=red, style=bold];
    Logger -> InfoSummarySystem [color=red, style=bold];
    UnifiedCacheManager -> UnifiedCacheManager [color=red, style=bold];
    UnifiedCacheManager -> PreferencesCore [color=red, style=bold];
}
