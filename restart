    echo "  -v, --verbose      Verbose output"
    echo "  --info             Show mode information"
    echo "  --status           Show current system status"
    echo ""
    echo "Examples:"
    echo "  $0                 # Automatic mode selection"
    echo "  $0 quick          # Force quick mode"
    echo "  $0 complete       # Force complete mode"
    echo "  $0 --interactive  # Ask user for choice"
    echo "  $0 --verbose      # Show detailed output"
