# Function to check system status
check_system_status() {
    echo "📊 TikTrack System Status"
    echo "========================="
    echo ""
    
    # Check if scripts exist
    if [ -f "$QUICK_SCRIPT" ]; then
        echo "✅ Quick restart script: $QUICK_SCRIPT"
    else
        echo "❌ Quick restart script missing: $QUICK_SCRIPT"
    fi
    
    if [ -f "$COMPLETE_SCRIPT" ]; then
        echo "✅ Complete restart script: $COMPLETE_SCRIPT"
    else
        echo "❌ Complete restart script missing: $COMPLETE_SCRIPT"
    fi
    
    echo ""
    
    # Check server status
    if pgrep -f "python3.*\(app\.py\|dev_server\.py\)" > /dev/null; then
        echo "🟢 Server is running"
    else
        echo "🔴 Server is not running"
    fi
    
    # Check port status
    if lsof -i :8080 > /dev/null 2>&1; then
        echo "⚠️  Port 8080 is in use"
    else
        echo "✅ Port 8080 is available"
    fi
    
    # Check memory usage
    local mem_usage=$(vm_stat | grep "Pages free" | awk '{print $3}' | sed 's/\.//')
    local mem_total=$(vm_stat | grep "Pages wired down" | awk '{print $4}' | sed 's/\.//')
    local mem_usage_percent=$((100 - (mem_usage * 100 / mem_total)))
    echo "💾 Memory usage: ${mem_usage_percent}%"
    
    # Check disk usage
    local disk_usage=$(df . | tail -1 | awk '{print $5}' | sed 's/%//')
    echo "💿 Disk usage: ${disk_usage}%"
    
    # Check recent errors
    if [ -f "$ERROR_LOG" ]; then
        local recent_errors=$(tail -20 "$ERROR_LOG" | grep -c "ERROR\|CRITICAL" || echo "0")
        echo "🚨 Recent errors: $recent_errors"
    else
        echo "✅ No error log found"
    fi
    
    # Check database locks
    local db_locks=$(find Backend/db/ -name "*.db-*" 2>/dev/null | wc -l)
    echo "🔒 Database locks: $db_locks"
    
    echo ""
}

# Function to detect optimal restart mode (silent version)
detect_optimal_mode() {
    local mode="quick"  # Default to quick mode
    local reasons=()
    
    # Check memory usage
    local mem_usage=$(vm_stat | grep "Pages free" | awk '{print $3}' | sed 's/\.//')
    local mem_total=$(vm_stat | grep "Pages wired down" | awk '{print $4}' | sed 's/\.//')
    local mem_usage_percent=$((100 - (mem_usage * 100 / mem_total)))
    
    if [ $mem_usage_percent -gt 90 ]; then
        mode="complete"
        reasons+=("High memory usage (${mem_usage_percent}%)")
    fi
    
    # Check recent errors
    if [ -f "$ERROR_LOG" ]; then
        local recent_errors=$(tail -20 "$ERROR_LOG" | grep -c "ERROR\|CRITICAL" || echo "0")
        if [ $recent_errors -gt 5 ]; then
            mode="complete"
            reasons+=("Many recent errors ($recent_errors)")
        fi
    fi
    
    # Check database locks
    local db_locks=$(find Backend/db/ -name "*.db-*" 2>/dev/null | wc -l)
    if [ $db_locks -gt 0 ]; then
        mode="complete"
        reasons+=("Database locks detected ($db_locks)")
    fi
    
    # Check if server is not running
    if ! pgrep -f "python3.*\(app\.py\|dev_server\.py\)" > /dev/null; then
        mode="complete"
        reasons+=("Server not running")
    fi
    
    # Check port conflicts
    if lsof -i :8080 > /dev/null 2>&1; then
        if [ "$mode" = "quick" ]; then
            reasons+=("Port 8080 in use")
        fi
    fi
    
    # Log detection results
    if [ ${#reasons[@]} -eq 0 ]; then
        log_info "✅ Quick mode recommended (no issues detected)"
    else
        log_info "🛡️ Complete mode recommended due to:"
        for reason in "${reasons[@]}"; do
            log_info "  - $reason"
        done
    fi
    
    # Return only the mode
    echo "$mode"
}

# Function to run quick restart
run_quick_restart() {
    log_info "⚡ Running quick restart mode..."
    
    if [ ! -f "$QUICK_SCRIPT" ]; then
        log_error "Quick restart script not found: $QUICK_SCRIPT"
        return 1
    fi
    
    if [ "$VERBOSE" = "true" ]; then
        bash "$QUICK_SCRIPT"
    else
        bash "$QUICK_SCRIPT" > /dev/null 2>&1
    fi
    
    if [ $? -eq 0 ]; then
        log_success "Quick restart completed successfully"
        return 0
    else
        log_error "Quick restart failed"
        return 1
    fi
}

# Function to run complete restart
run_complete_restart() {
    log_info "🛡️ Running complete restart mode..."
    
    if [ ! -f "$COMPLETE_SCRIPT" ]; then
        log_error "Complete restart script not found: $COMPLETE_SCRIPT"
        return 1
    fi
    
    if [ "$VERBOSE" = "true" ]; then
        bash "$COMPLETE_SCRIPT"
    else
        bash "$COMPLETE_SCRIPT"
    fi
    
    if [ $? -eq 0 ]; then
        log_success "Complete restart completed successfully"
        return 0
    else
        log_error "Complete restart failed"
        return 1
    fi
}

# Function to show interactive choice
show_interactive_choice() {
    echo ""
    echo "🔄 TikTrack Server Restart - Interactive Mode"
    echo "============================================="
    echo ""
    echo "Choose restart mode:"
    echo ""
    echo "1) ⚡ Quick Mode (5-10 seconds)"
    echo "   - Fast restart for development"
    echo "   - Basic health checks"
    echo "   - Minimal logging"
    echo ""
    echo "2) 🛡️ Complete Mode (30-60 seconds)"
    echo "   - Comprehensive restart"
    echo "   - Full system analysis"
    echo "   - Route validation"
    echo "   - Automatic problem fixing"
    echo ""
    echo "3) 🤖 Auto Mode (Smart detection)"
    echo "   - Automatic mode selection"
    echo "   - Based on system health"
    echo ""
    echo "4) 📊 Show System Status"
    echo "   - Current system information"
    echo ""
    echo "5) ❌ Cancel"
    echo ""
    
    read -p "Enter your choice (1-5): " choice
    
    case $choice in
        1)
            log_info "User selected: Quick Mode"
            run_quick_restart
            ;;
        2)
            log_info "User selected: Complete Mode"
            run_complete_restart
            ;;
        3)
            log_info "User selected: Auto Mode"
            local optimal_mode=$(detect_optimal_mode)
            log_info "Auto-detected mode: $optimal_mode"
            if [ "$optimal_mode" = "complete" ]; then
                run_complete_restart
            else
                run_quick_restart
            fi
            ;;
        4)
            check_system_status
            show_interactive_choice  # Show menu again
            ;;
        5)
            log_info "Restart cancelled by user"
            exit 0
            ;;
        *)
            log_error "Invalid choice: $choice"
            show_interactive_choice  # Show menu again
            ;;
    esac
}

# Main execution
main() {
    local mode="auto"
    local interactive=false
    local verbose=false
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            quick|--quick)
                mode="quick"
                shift
                ;;
            complete|--complete)
                mode="complete"
                shift
                ;;
            auto|--auto)
                mode="auto"
                shift
                ;;
            -i|--interactive)
                interactive=true
                shift
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --info)
                show_mode_info
                exit 0
                ;;
            --status)
                check_system_status
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Set global variables
    VERBOSE="$verbose"
    
    # Header
    echo "🔄 TikTrack Unified Server Restart Script"
    echo "=========================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Mode: $mode"
    echo ""
    
    # Check if scripts exist
    if [ ! -f "$QUICK_SCRIPT" ]; then
        log_error "Quick restart script not found: $QUICK_SCRIPT"
        exit 1
    fi
    
    if [ ! -f "$COMPLETE_SCRIPT" ]; then
        log_error "Complete restart script not found: $COMPLETE_SCRIPT"
        exit 1
    fi
    
    # Interactive mode
    if [ "$interactive" = "true" ]; then
        show_interactive_choice
        exit 0
    fi
    
    # Determine restart mode
    if [ "$mode" = "auto" ]; then
        log_info "🔍 Auto-detecting optimal restart mode..."
        # Call detection function and capture result
        detected_mode=$(detect_optimal_mode | tail -1)
        mode="$detected_mode"
        log_info "Selected mode: $mode"
    fi
    
    # Execute restart
    case $mode in
        quick)
            run_quick_restart
            ;;
        complete)
            run_complete_restart
            ;;
        *)
            log_error "Invalid mode: $mode"
            exit 1
            ;;
    esac
    
    # Final status
    if [ $? -eq 0 ]; then
        log_success "✅ Server restart completed successfully"
        echo ""
        echo "🎉 Restart completed!"
        echo "🌐 Server should be available at: http://localhost:8080"
        echo ""
    else
        log_error "❌ Server restart failed"
        echo ""
        echo "💡 Troubleshooting tips:"
        echo "  - Try complete mode: $0 complete"
        echo "  - Check logs: tail -f $DETAILED_LOG"
        echo "  - Interactive mode: $0 --interactive"
        echo ""
        exit 1
    fi
}

# Run main function
main "$@"
