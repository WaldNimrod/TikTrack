# 
# 📖 Documentation: documentation/server/RESTART_SCRIPT_GUIDE.md
# 🔗 Related: documentation/server/README.md
# 
# 🆕 Version: 2.0 (August 24, 2025)
# 🛠️ Features: Smart mode detection, user choice, comprehensive logging
# 
# 🔧 RESTART MODES EXPLAINED
# ==========================
# 
# QUICK MODE (restart_server_quick.sh):
# --------------------------------------
# ⚡ Speed: Fast restart (5-10 seconds)
# 🎯 Use Case: Development, testing, minor changes
# ✅ Features:
#   - Stops server processes
#   - Cleans port conflicts
#   - Basic health checks
#   - Simple API testing
#   - Minimal logging
# ❌ Limitations:
#   - No deep system checks
#   - No cache cleanup
#   - No route validation
#   - Limited error recovery
# 
# COMPLETE MODE (restart_server_complete.sh):
# -------------------------------------------
# 🛡️ Stability: Comprehensive restart (30-60 seconds)
# 🎯 Use Case: Production, troubleshooting, major issues
# ✅ Features:
#   - Complete system analysis
#   - Database lock cleanup
#   - Cache and temp file cleanup
#   - Package dependency checks
#   - Route validation (23+ endpoints)
#   - Performance monitoring
#   - Automatic problem fixing
#   - Detailed error analysis
#   - Comprehensive logging
# ❌ Limitations:
#   - Slower startup time
#   - More resource intensive
# 
# SMART DETECTION LOGIC:
# ======================
# 
# The script automatically chooses the appropriate mode based on:
# 
# 1. SYSTEM HEALTH INDICATORS:
#    - Memory usage > 90% → Complete mode
#    - Recent errors in logs → Complete mode
#    - Database lock files → Complete mode
#    - Port conflicts → Quick mode
# 
# 2. USER ACTIVITY PATTERNS:
#    - Development session < 1 hour → Quick mode
#    - Production environment → Complete mode
#    - Recent code changes → Complete mode
# 
# 3. ERROR PATTERNS:
#    - Route failures → Complete mode
#    - Import errors → Complete mode
#    - Database errors → Complete mode
#    - Simple port conflicts → Quick mode
# 
# USAGE EXAMPLES:
# ===============
# 
# Automatic mode selection:
#   ./restart                    # Smart detection
# 
# Force specific mode:
#   ./restart quick             # Force quick mode
#   ./restart complete          # Force complete mode
#   ./restart --quick           # Alternative syntax
#   ./restart --complete        # Alternative syntax
# 
# Interactive mode:
#   ./restart --interactive     # Ask user for choice
# 
# Verbose mode:
#   ./restart --verbose         # Show detailed output
# 
# HELP AND INFORMATION:
# =====================
# 
# Show help:
#   ./restart --help            # Show this help
#   ./restart -h                # Short help
# 
# Show mode information:
#   ./restart --info            # Show mode details
#   ./restart --status          # Show current system status
# 
# TROUBLESHOOTING:
# ================
# 
# If quick mode fails:
#   ./restart complete          # Try complete mode
# 
# If complete mode is too slow:
#   ./restart quick             # Try quick mode
# 
# For persistent issues:
#   ./restart --verbose complete # Get detailed diagnostics
# 
# SCRIPT EVOLUTION:
# =================
# 
# Version 2.0 (August 24, 2025):
# - Unified interface for both restart modes
# - Smart automatic mode detection
# - Interactive user choice
# - Comprehensive documentation
# - Enhanced error handling
# - Performance optimization
# 
# Version 1.x (Previous):
# - Separate scripts for different modes
# - Manual mode selection
# - Basic functionality

set -e  # Exit on any error

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QUICK_SCRIPT="$SCRIPT_DIR/restart_server_quick.sh"
COMPLETE_SCRIPT="$SCRIPT_DIR/restart_server_complete.sh"
LOG_DIR="logs"
DETAILED_LOG="server_detailed.log"
ERROR_LOG="logs/errors.log"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Timestamp function
timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Logging functions
log_info() {
    echo -e "${BLUE}[$(timestamp)] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(timestamp)] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(timestamp)] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(timestamp)] ERROR:${NC} $1"
}

log_debug() {
    echo -e "${PURPLE}[$(timestamp)] DEBUG:${NC} $1"
}

