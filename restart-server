# Function to detect current cache state
detect_current_cache_state() {
    log_info "🔍 Detecting current cache state..."
    
    # Check if server is running and get cache stats
    if curl -s "http://localhost:8080/api/cache/stats" > /dev/null 2>&1; then
        local cache_response=$(curl -s "http://localhost:8080/api/cache/stats" 2>/dev/null)
        if [ $? -eq 0 ] && [ -n "$cache_response" ]; then
            # Extract cache statistics using jq if available, otherwise use grep
            if command -v jq >/dev/null 2>&1; then
                local total_entries=$(echo "$cache_response" | jq -r '.data.total_entries // 0')
                local total_requests=$(echo "$cache_response" | jq -r '.data.total_requests // 0')
                local sets=$(echo "$cache_response" | jq -r '.data.stats.sets // 0')
                local hits=$(echo "$cache_response" | jq -r '.data.stats.hits // 0')
                local deletes=$(echo "$cache_response" | jq -r '.data.stats.deletes // 0')
            else
                local total_entries=$(echo "$cache_response" | grep -o '"total_entries":[0-9]*' | cut -d: -f2 || echo "0")
                local total_requests=$(echo "$cache_response" | grep -o '"total_requests":[0-9]*' | cut -d: -f2 || echo "0")
                local sets=$(echo "$cache_response" | grep -o '"sets":[0-9]*' | cut -d: -f2 || echo "0")
                local hits=$(echo "$cache_response" | grep -o '"hits":[0-9]*' | cut -d: -f2 || echo "0")
                local deletes=$(echo "$cache_response" | grep -o '"deletes":[0-9]*' | cut -d: -f2 || echo "0")
            fi
            
            # Ensure all values are numbers
            total_entries=${total_entries:-0}
            total_requests=${total_requests:-0}
            sets=${sets:-0}
            hits=${hits:-0}
            deletes=${deletes:-0}
            
            log_info "Cache stats: entries=$total_entries, requests=$total_requests, sets=$sets, hits=$hits, deletes=$deletes"
            
            # Determine cache state based on statistics
            if [ "$total_entries" -eq 0 ] && [ "$total_requests" -eq 0 ] && [ "$sets" -eq 0 ]; then
                log_info "Current cache state: NO-CACHE (all stats are 0)"
                echo "no-cache"
                return 0
            elif [ "$sets" -gt 0 ] && [ "$deletes" -gt 0 ]; then
                log_info "Current cache state: DEVELOPMENT (high activity with deletes)"
                echo "development"
                return 0
            elif [ "$sets" -gt 0 ] && [ "$hits" -gt 0 ]; then
                log_info "Current cache state: PRODUCTION (activity with hits)"
                echo "production"
                return 0
            elif [ "$sets" -gt 0 ]; then
                log_info "Current cache state: DEVELOPMENT (initial activity)"
                echo "development"
                return 0
            else
                log_info "Current cache state: NO-CACHE (no activity)"
                echo "no-cache"
                return 0
            fi
        fi
    fi
    
    # Fallback: check environment variables
    if [ "$TIKTRACK_DEV_MODE" = "true" ]; then
        if [ "$TIKTRACK_CACHE_DISABLED" = "true" ]; then
            log_info "Current cache state: NO-CACHE (from environment)"
            echo "no-cache"
        else
            log_info "Current cache state: DEVELOPMENT (from environment)"
            echo "development"
        fi
    else
        log_info "Current cache state: PRODUCTION (default)"
        echo "production"
    fi
}

# Function to set cache environment
set_cache_environment() {
    local cache_mode="$1"
    
    case $cache_mode in
        development)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: DEVELOPMENT (10 seconds TTL)"
            ;;
        no-cache)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="true"
            log_info "Cache mode: NO-CACHE (disabled)"
            ;;
        production)
            export TIKTRACK_DEV_MODE="false"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: PRODUCTION (5 minutes TTL)"
            ;;
        preserve)
            # Detect and preserve current state
            local current_state=$(detect_current_cache_state)
            log_info "Preserving current cache state: $current_state"
            # Avoid infinite recursion by calling the specific case directly
            case $current_state in
                development)
                    export TIKTRACK_DEV_MODE="true"
                    export TIKTRACK_CACHE_DISABLED="false"
                    log_info "Cache mode preserved as: DEVELOPMENT (10 seconds TTL)"
                    ;;
                no-cache)
                    export TIKTRACK_DEV_MODE="true"
                    export TIKTRACK_CACHE_DISABLED="true"
                    log_info "Cache mode preserved as: NO-CACHE (disabled)"
                    ;;
                production)
                    export TIKTRACK_DEV_MODE="false"
                    export TIKTRACK_CACHE_DISABLED="false"
                    log_info "Cache mode preserved as: PRODUCTION (5 minutes TTL)"
                    ;;
                custom)
                    log_info "Cache mode preserved as: CUSTOM (unknown TTL)"
                    ;;
            esac
            ;;
        *)
            log_error "Invalid cache mode: $cache_mode"
            log_error "Valid modes: development, no-cache, production, preserve"
            return 1
            ;;
    esac
}

# Function to stop server processes (improved)
stop_server() {
    log_info "🛑 Stopping server processes..."
    
    # Find all Python processes with dev_server.py
    local pids=$(pgrep -f "python.*dev_server.py" 2>/dev/null || true)
    if [ -z "$pids" ]; then
        # Try alternative patterns
        pids=$(pgrep -f "dev_server.py" 2>/dev/null || true)
    fi
    
    if [ -n "$pids" ]; then
        log_info "Found running server processes: $pids"
        
        # Try graceful shutdown first
        pkill -f "python.*dev_server.py" 2>/dev/null || true
        sleep 3
        
        # Check if processes are still running
        local remaining_pids=$(pgrep -f "python.*dev_server.py" 2>/dev/null || true)
        if [ -n "$remaining_pids" ]; then
            log_warning "Processes still running after graceful shutdown: $remaining_pids"
            log_warning "Force killing remaining processes..."
            pkill -9 -f "python.*dev_server.py" 2>/dev/null || true
            sleep 2
        fi
        
        # Final check
        local final_pids=$(pgrep -f "python.*dev_server.py" 2>/dev/null || true)
        if [ -n "$final_pids" ]; then
            log_error "Failed to stop server processes: $final_pids"
            return 1
        else
            log_success "All server processes stopped successfully"
        fi
    else
        log_info "No server processes found"
    fi
    
    # Additional cleanup - kill any processes on port 8080
    local port_pids=$(lsof -ti:8080 2>/dev/null || true)
    if [ -n "$port_pids" ]; then
        log_info "Found processes on port 8080: $port_pids"
        kill -9 $port_pids 2>/dev/null || true
        sleep 1
    fi
}

# Function to detect optimal restart mode
detect_optimal_mode() {
    log_info "🔍 Detecting optimal restart mode..."
    
    # Check system resources
    local memory_usage=$(free 2>/dev/null | grep Mem | awk '{printf "%.0f", $3/$2 * 100.0}' || echo "0")
    local disk_usage=$(df / 2>/dev/null | tail -1 | awk '{print $5}' | sed 's/%//' || echo "0")
    
    log_info "Memory usage: ${memory_usage}%"
    log_info "Disk usage: ${disk_usage}%"
    
    # Check for recent errors in logs
    local recent_errors=0
    if [ -f "$LOG_FILE" ]; then
        recent_errors=$(grep -c "ERROR\|CRITICAL" "$LOG_FILE" 2>/dev/null || echo "0")
    fi
    log_info "Recent errors in logs: $recent_errors"
    
    # Check if server is responding
    local server_responding=false
    if curl -s "http://localhost:8080/api/health" > /dev/null 2>&1; then
        server_responding=true
        log_info "Server is currently responding"
    else
        log_info "Server is not responding"
    fi
    
    # Decision logic
    if [ "$memory_usage" -gt 90 ] || [ "$disk_usage" -gt 90 ] || [ "$recent_errors" -gt 10 ] || [ "$server_responding" = false ]; then
        log_info "System indicators suggest COMPLETE mode"
        echo "complete"
    else
        log_info "System indicators suggest QUICK mode"
        echo "quick"
    fi
}

# Function to run quick restart
run_quick_restart() {
    local cache_mode="$1"
    log_info "⚡ Running quick restart mode..."
    
    # Use the existing quick script if available
    if [ -f "$QUICK_SCRIPT" ]; then
        log_info "Using existing quick restart script: $QUICK_SCRIPT"
        
        # Pass cache environment variables to quick script
        export TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE"
        export TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED"
        
        if [ "$VERBOSE" = "true" ]; then
            bash "$QUICK_SCRIPT"
            local exit_code=$?
        else
            bash "$QUICK_SCRIPT" > /dev/null 2>&1
            local exit_code=$?
        fi
        
        if [ $exit_code -eq 0 ]; then
            log_success "Quick restart completed successfully"
            return 0
        else
            log_error "Quick restart failed with exit code: $exit_code"
            return 1
        fi
    else
        # Fallback to direct server control
        log_info "Quick script not found, using direct server control"
        stop_server
        start_server_direct "$cache_mode"
    fi
}

