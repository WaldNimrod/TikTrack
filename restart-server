    read -p "Enter your choice (1-5): " cache_choice
    
    case $cache_choice in
        1)
            log_info "User selected: Development Cache Mode"
            set_cache_environment "development"
            show_interactive_choice "development"  # Show main menu again
            ;;
        2)
            log_info "User selected: No-Cache Mode"
            set_cache_environment "no-cache"
            show_interactive_choice "no-cache"  # Show main menu again
            ;;
        3)
            log_info "User selected: Production Cache Mode"
            set_cache_environment "production"
            show_interactive_choice "production"  # Show main menu again
            ;;
        4)
            log_info "User selected: Keep Current Cache State"
            set_cache_environment "preserve"
            show_interactive_choice "preserve"  # Show main menu again
            ;;
        5)
            show_interactive_choice "preserve"  # Show main menu again
            ;;
        *)
            log_error "Invalid choice: $cache_choice"
            show_cache_mode_selection  # Show menu again
            ;;
    esac
}

# Main execution
main() {
    local mode="quick"
    local cache_mode="preserve"
    local interactive=false
    local verbose=false
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            quick|--quick)
                mode="quick"
                shift
                ;;
            complete|--complete)
                mode="complete"
                shift
                ;;
            auto|--auto)
                mode="auto"
                shift
                ;;
            development|no-cache|production|preserve)
                cache_mode="$1"
                shift
                ;;
            -i|--interactive)
                interactive=true
                shift
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --info)
                show_mode_info
                exit 0
                ;;
            --status)
                show_server_status
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Set global variables
    VERBOSE="$verbose"
    
    # Header
    echo "🔄 TikTrack Server Restart - Complete Unified Command"
    echo "====================================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Mode: $mode"
    echo "🧠 Cache: $cache_mode"
    echo ""
    
    # Interactive mode
    if [ "$interactive" = "true" ]; then
        show_interactive_choice "$cache_mode"
        exit 0
    fi
    
    # Set cache environment based on user choice
    log_info "Setting cache mode: $cache_mode"
    set_cache_environment "$cache_mode"
    
    # Determine restart mode
    if [ "$mode" = "auto" ]; then
        log_info "🔍 Auto-detecting optimal restart mode..."
        detected_mode=$(detect_optimal_mode | tail -1)
        mode="$detected_mode"
        log_info "Selected mode: $mode"
    fi
    
    # Execute restart
    case $mode in
        quick)
            run_quick_restart "$cache_mode"
            ;;
        complete)
            run_complete_restart "$cache_mode"
            ;;
        *)
            log_error "Invalid mode: $mode"
            exit 1
            ;;
    esac
    
    # Final status
    local final_exit_code=$?
    if [ $final_exit_code -eq 0 ]; then
        # Verify cache mode
        verify_cache_mode "$cache_mode"
        
        # Show final status
        show_server_status
        
        log_success "✅ Server restart completed successfully"
        echo ""
        echo "🎉 Restart completed!"
        echo "🌐 Server should be available at: http://localhost:8080"
        echo ""
        
        # Show cache state after restart
        echo "🧠 Cache State After Restart:"
        echo "=============================="
        case $cache_mode in
            development)
                echo "   Mode: DEVELOPMENT (10 seconds TTL)"
                ;;
            no-cache)
                echo "   Mode: NO-CACHE (disabled)"
                ;;
            production)
                echo "   Mode: PRODUCTION (5 minutes TTL)"
                ;;
            preserve)
                echo "   Mode: PRESERVED (current state maintained)"
                ;;
        esac
        echo ""
        
        # Show additional help if this was a quick restart
        if [ "$mode" = "quick" ]; then
            echo "💡 If you experience issues, consider complete restart:"
            echo "   $0 complete"
            echo ""
        fi
    else
        log_error "❌ Server restart failed with exit code: $final_exit_code"
        echo ""
        echo "💡 TROUBLESHOOTING REQUIRED:"
        echo "============================="
        echo ""
        echo "Quick restart failed. Try these solutions in order:"
        echo ""
        echo "1️⃣  COMPLETE RESTART (Recommended):"
        echo "   $0 complete"
        echo ""
        echo "2️⃣  INTERACTIVE MODE (Guided troubleshooting):"
        echo "   $0 --interactive"
        echo ""
        echo "3️⃣  VERBOSE DIAGNOSTICS:"
        echo "   $0 --verbose complete"
        echo ""
        echo "4️⃣  CHECK LOGS:"
        echo "   tail -f $LOG_FILE"
        echo ""
        echo "The complete mode performs comprehensive system analysis"
        echo "and automatic problem fixing that the quick mode doesn't include."
        echo ""
        exit $final_exit_code
    fi
}

# Run main function
main "$@"