# Function to perform comprehensive system checks
perform_comprehensive_checks() {
    log_info "🔍 Performing comprehensive system checks..."
    
    # Check disk space
    local disk_usage=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    if [ "$disk_usage" -gt 90 ]; then
        log_warning "Disk usage is high: ${disk_usage}%"
    else
        log_info "Disk usage is acceptable: ${disk_usage}%"
    fi
    
    # Check memory
    local memory_usage=$(free | grep Mem | awk '{printf "%.0f", $3/$2 * 100.0}')
    if [ "$memory_usage" -gt 90 ]; then
        log_warning "Memory usage is high: ${memory_usage}%"
    else
        log_info "Memory usage is acceptable: ${memory_usage}%"
    fi
    
    # Check for database locks
    if [ -f "$SCRIPT_DIR/Backend/db/simpleTrade_new.db" ]; then
        log_info "Database file exists and is accessible"
    else
        log_warning "Database file not found or not accessible"
    fi
    
    # Check Python dependencies
    if python3 -c "import flask" 2>/dev/null; then
        log_info "Flask dependency is available"
    else
        log_error "Flask dependency is missing"
        return 1
    fi
    
    log_success "Comprehensive system checks completed"
}

# Function to start server directly
start_server_direct() {
    local cache_mode="$1"
    
    log_info "🚀 Starting server directly with $cache_mode cache mode..."
    
    # Change to project directory
    cd "$SCRIPT_DIR"
    
    # Start server in background
    nohup python3 "$SERVER_SCRIPT" > /dev/null 2>&1 &
    local server_pid=$!
    
    log_info "Server started with PID: $server_pid"
    
    # Wait for server to start
    log_info "⏳ Waiting for server to initialize..."
    sleep 3
    
    # Check if server is responding
    local max_attempts=10
    local attempt=1
    
    while [ $attempt -le $max_attempts ]; do
        if curl -s "http://localhost:8080/api/health" > /dev/null 2>&1; then
            log_success "Server is responding on http://localhost:8080"
            return 0
        fi
        
        log_info "Attempt $attempt/$max_attempts: Server not ready yet..."
        sleep 2
        attempt=$((attempt + 1))
    done
    
    log_error "Server failed to start or respond after $max_attempts attempts"
    return 1
}

# Function to verify cache mode
verify_cache_mode() {
    local expected_mode="$1"
    
    log_info "🔍 Verifying cache mode..."
    
    # Wait a bit for cache to initialize
    sleep 2
    
    # Get cache stats
    local cache_response=$(curl -s "http://localhost:8080/api/cache/stats" 2>/dev/null)
    
    if [ $? -eq 0 ] && [ -n "$cache_response" ]; then
        # Extract cache statistics
        if command -v jq >/dev/null 2>&1; then
            local sets=$(echo "$cache_response" | jq -r '.data.stats.sets // 0')
            local hits=$(echo "$cache_response" | jq -r '.data.stats.hits // 0')
            local deletes=$(echo "$cache_response" | jq -r '.data.stats.deletes // 0')
        else
            local sets=$(echo "$cache_response" | grep -o '"sets":[0-9]*' | cut -d: -f2 || echo "0")
            local hits=$(echo "$cache_response" | grep -o '"hits":[0-9]*' | cut -d: -f2 || echo "0")
            local deletes=$(echo "$cache_response" | grep -o '"deletes":[0-9]*' | cut -d: -f2 || echo "0")
        fi
        
        log_info "Cache stats: sets=$sets, hits=$hits, deletes=$deletes"
        
        # Verify cache mode based on stats
        case $expected_mode in
            development)
                if [ "$sets" -gt 0 ]; then
                    log_success "✅ Development cache mode confirmed (sets > 0)"
                else
                    log_warning "⚠️  Development cache mode not confirmed (sets = 0)"
                fi
                ;;
            no-cache)
                if [ "$sets" -eq 0 ] && [ "$hits" -eq 0 ]; then
                    log_success "✅ No-cache mode confirmed (all stats = 0)"
                else
                    log_warning "⚠️  No-cache mode not confirmed (stats > 0)"
                fi
                ;;
            production)
                if [ "$sets" -gt 0 ]; then
                    log_success "✅ Production cache mode confirmed (sets > 0)"
                else
                    log_warning "⚠️  Production cache mode not confirmed (sets = 0)"
                fi
                ;;
            preserve)
                log_success "✅ Cache state preserved (current state maintained)"
                ;;
        esac
    else
        log_warning "Could not verify cache mode (API not responding)"
    fi
}

