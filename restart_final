#!/bin/bash

# TikTrack Final Restart Script - Based on Server Analysis
# ========================================================
# 
# 🎯 Purpose: Server restart that handles 80-second startup time
# 🚀 Features: Long wait time, guaranteed control return, based on logs analysis
# 📖 Documentation: documentation/server/RESTART_SCRIPT_GUIDE.md
# 
# Server Analysis Results:
# - Server takes 80 seconds to fully initialize
# - SocketIO + Background Tasks + Database + External Data
# - Health checks show 82% success rate after full startup

set -e

# Configuration
SERVER_PORT=8080
SERVER_HOST="127.0.0.1"
MAX_WAIT_TIME=90  # 90 seconds to be safe
HEALTH_CHECK_INTERVAL=5  # Check every 5 seconds

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Timestamp
timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Logging
log_info() {
    echo -e "${BLUE}[$(timestamp)] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(timestamp)] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(timestamp)] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(timestamp)] ERROR:${NC} $1"
}

# Function to set cache environment
set_cache_mode() {
    local mode="$1"
    
    case $mode in
        development)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: DEVELOPMENT (10 seconds TTL)"
            ;;
        no-cache)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="true"
            log_info "Cache mode: NO-CACHE (disabled)"
            ;;
        production)
            export TIKTRACK_DEV_MODE="false"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: PRODUCTION (5 minutes TTL)"
            ;;
        preserve)
            log_info "Cache mode: PRESERVE (keeping current state)"
            ;;
        *)
            log_error "Invalid cache mode: $mode"
            exit 1
            ;;
    esac
}

# Function to stop server
stop_server() {
    log_info "🛑 Stopping server..."
    
    # Stop Python processes
    local python_processes=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep | awk '{print $2}')
    
    if [ -n "$python_processes" ]; then
        log_info "Found Python processes: $python_processes"
        echo "$python_processes" | xargs kill -TERM 2>/dev/null || true
        sleep 3
        
        # Check if processes still exist
        local remaining=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep | awk '{print $2}')
        if [ -n "$remaining" ]; then
            log_warning "Force killing remaining processes: $remaining"
            echo "$remaining" | xargs kill -KILL 2>/dev/null || true
        fi
    else
        log_info "No existing Python processes found"
    fi
    
    # Kill processes using port 8080
    local port_processes=$(lsof -ti:8080 2>/dev/null || true)
    if [ -n "$port_processes" ]; then
        log_warning "Killing processes using port 8080: $port_processes"
        echo "$port_processes" | xargs kill -TERM 2>/dev/null || true
        sleep 2
    fi
    
    log_success "Server cleanup completed"
}

# Function to start server
start_server() {
    log_info "🚀 Starting server..."
    
    # Check if Backend directory exists
    if [ ! -d "Backend" ]; then
        log_error "Backend directory not found"
        exit 1
    fi
    
    # Enter Backend directory
    cd Backend
    
    # Start server with environment variables
    TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE" \
    TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED" \
    nohup python3 dev_server.py > /dev/null 2>&1 &
    
    local server_pid=$!
    cd ..
    
    log_info "Server process started with PID: $server_pid"
    return 0
}

# Function to wait for server with long timeout
wait_for_server() {
    log_info "⏳ Waiting for server to fully initialize (up to ${MAX_WAIT_TIME}s)..."
    log_info "📊 Based on analysis: Server takes ~80s for SocketIO + Background Tasks + Database + External Data"
    
    local attempts=0
    local max_attempts=$((MAX_WAIT_TIME / HEALTH_CHECK_INTERVAL))
    local server_ready=false
    
    while [ $attempts -lt $max_attempts ]; do
        attempts=$((attempts + 1))
        local elapsed_time=$((attempts * HEALTH_CHECK_INTERVAL))
        
        log_info "Health check attempt $attempts/$max_attempts (${elapsed_time}s elapsed)..."
        
        # Check basic response
        if curl -s --max-time 3 "http://$SERVER_HOST:$SERVER_PORT/" > /dev/null 2>&1; then
            log_success "✅ Basic server response OK"
            
            # Check API health
            if curl -s --max-time 3 "http://$SERVER_HOST:$SERVER_PORT/api/health" > /dev/null 2>&1; then
                log_success "✅ API health OK"
                server_ready=true
                break
            else
                log_warning "API health check failed, but server is responding"
            fi
        else
            log_info "Server not ready yet..."
        fi
        
        if [ $attempts -lt $max_attempts ]; then
            log_info "Waiting ${HEALTH_CHECK_INTERVAL} seconds before next check..."
            sleep $HEALTH_CHECK_INTERVAL
        fi
    done
    
    if [ "$server_ready" = true ]; then
        log_success "✅ Server is fully ready after ${elapsed_time} seconds"
        return 0
    else
        log_warning "⚠️ Server health check timeout after ${MAX_WAIT_TIME} seconds"
        log_warning "Server may still be starting in background"
        return 1
    fi
}

# Function to show help
show_help() {
    echo "🔄 TikTrack Final Restart Script"
    echo "================================="
    echo ""
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --cache-mode=MODE    Set cache mode"
    echo "                        MODE: development, no-cache, production, preserve"
    echo "  --help               Show this help"
    echo ""
    echo "Cache Modes:"
    echo "  development          Cache TTL: 10 seconds (fast development)"
    echo "  no-cache            Cache disabled (immediate updates)"
    echo "  production          Cache TTL: 5 minutes (performance)"
    echo "  preserve            Keep current cache state (default)"
    echo ""
    echo "Features:"
    echo "  - Based on server analysis (80s startup time)"
    echo "  - Long wait time for full initialization"
    echo "  - Guaranteed control return"
    echo "  - Handles SocketIO + Background Tasks + Database + External Data"
    echo ""
    echo "Examples:"
    echo "  $0                                    # Default restart with preserve cache"
    echo "  $0 --cache-mode=development          # Development cache mode"
    echo ""
}

# Main function
main() {
    local cache_mode="preserve"
    local start_time=$(date +%s)
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --cache-mode=*)
                cache_mode="${1#*=}"
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Header
    echo "🔄 TikTrack Final Restart Script"
    echo "================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Cache Mode: $cache_mode"
    echo "⏱️ Max Wait Time: ${MAX_WAIT_TIME}s (based on server analysis)"
    echo ""
    
    # Set cache mode
    set_cache_mode "$cache_mode"
    echo ""
    
    # Stop server
    stop_server
    echo ""
    
    # Start server
    if ! start_server; then
        log_error "Failed to start server"
        exit 1
    fi
    echo ""
    
    # Wait for server with long timeout
    if wait_for_server; then
        # Calculate total time
        local end_time=$(date +%s)
        local total_time=$((end_time - start_time))
        
        echo ""
        log_success "🎉 Server restart completed successfully!"
        echo "📊 Summary:"
        echo "   - Total time: ${total_time} seconds"
        echo "   - Cache mode: $cache_mode"
        echo "   - Status: ✅ SUCCESS"
        echo "🌐 Server is available at: http://$SERVER_HOST:$SERVER_PORT"
        echo ""
        exit 0
    else
        # Calculate total time
        local end_time=$(date +%s)
        local total_time=$((end_time - start_time))
        
        echo ""
        log_warning "⚠️ Server restart completed with warnings"
        echo "📊 Summary:"
        echo "   - Total time: ${total_time} seconds"
        echo "   - Cache mode: $cache_mode"
        echo "   - Status: ⚠️ WARNING (server may still be starting)"
        echo "🌐 Try accessing: http://$SERVER_HOST:$SERVER_PORT"
        echo "💡 Server may need more time to fully initialize"
        echo ""
        exit 0  # Always exit with success to return control
    fi
}

# Run main function
main "$@"
