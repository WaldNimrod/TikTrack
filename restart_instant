#!/bin/bash

# TikTrack Instant Restart Script
# ================================
# 
# 🎯 Purpose: Instant server restart that returns control immediately
# 🚀 Features: Start server, return control, no waiting
# 📖 Based on: start_dev.sh working approach
# 
# This script starts the server and immediately returns control,
# just like the working start_dev.sh script.

set -e

# Configuration
SERVER_PORT=8080

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Timestamp
timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Logging
log_info() {
    echo -e "${BLUE}[$(timestamp)] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(timestamp)] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(timestamp)] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(timestamp)] ERROR:${NC} $1"
}

# Function to set cache environment
set_cache_mode() {
    local mode="$1"
    
    case $mode in
        development)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: DEVELOPMENT (10 seconds TTL)"
            ;;
        no-cache)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="true"
            log_info "Cache mode: NO-CACHE (disabled)"
            ;;
        production)
            export TIKTRACK_DEV_MODE="false"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: PRODUCTION (5 minutes TTL)"
            ;;
        preserve)
            log_info "Cache mode: PRESERVE (keeping current state)"
            ;;
        *)
            log_error "Invalid cache mode: $mode"
            exit 1
            ;;
    esac
}

# Function to stop server (based on start_dev.sh)
stop_server() {
    log_info "🛑 Stopping server..."
    
    # Check if there are processes running on the port
    if lsof -i :$SERVER_PORT >/dev/null 2>&1; then
        log_warning "There are processes running on port $SERVER_PORT"
        log_info "Stopping existing processes..."
        lsof -ti :$SERVER_PORT | xargs kill -9 2>/dev/null || true
        sleep 2
    else
        log_info "No existing processes found on port $SERVER_PORT"
    fi
    
    log_success "Server cleanup completed"
}

# Function to start server (based on start_dev.sh)
start_server() {
    log_info "🚀 Starting server..."
    
    # Check if Backend directory exists
    if [ ! -d "Backend" ]; then
        log_error "Backend directory not found"
        exit 1
    fi
    
    # Enter Backend directory
    cd Backend
    
    # Start server with environment variables (like start_dev.sh)
    TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE" \
    TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED" \
    nohup python3 dev_server.py > /dev/null 2>&1 &
    
    local server_pid=$!
    cd ..
    
    log_success "Server process started with PID: $server_pid"
    log_info "Server is starting in background..."
    log_info "No waiting - control returned immediately"
    
    return 0
}

# Function to show help
show_help() {
    echo "🔄 TikTrack Instant Restart Script"
    echo "==================================="
    echo ""
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --cache-mode=MODE    Set cache mode"
    echo "                        MODE: development, no-cache, production, preserve"
    echo "  --help               Show this help"
    echo ""
    echo "Cache Modes:"
    echo "  development          Cache TTL: 10 seconds (fast development)"
    echo "  no-cache            Cache disabled (immediate updates)"
    echo "  production          Cache TTL: 5 minutes (performance)"
    echo "  preserve            Keep current cache state (default)"
    echo ""
    echo "Features:"
    echo "  - Based on working start_dev.sh approach"
    echo "  - Instant control return (no waiting)"
    echo "  - Server starts in background"
    echo "  - Simple and reliable"
    echo ""
    echo "Examples:"
    echo "  $0                                    # Default restart with preserve cache"
    echo "  $0 --cache-mode=development          # Development cache mode"
    echo ""
}

# Main function
main() {
    local cache_mode="preserve"
    local start_time=$(date +%s)
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --cache-mode=*)
                cache_mode="${1#*=}"
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Header
    echo "🔄 TikTrack Instant Restart Script"
    echo "==================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Cache Mode: $cache_mode"
    echo "⚡ Approach: Instant control return (no waiting)"
    echo ""
    
    # Set cache mode
    set_cache_mode "$cache_mode"
    echo ""
    
    # Stop server
    stop_server
    echo ""
    
    # Start server
    if start_server; then
        # Calculate total time
        local end_time=$(date +%s)
        local total_time=$((end_time - start_time))
        
        echo ""
        log_success "🎉 Server restart completed successfully!"
        echo "📊 Summary:"
        echo "   - Total time: ${total_time} seconds"
        echo "   - Cache mode: $cache_mode"
        echo "   - Status: ✅ SUCCESS"
        echo "   - Control: ✅ RETURNED IMMEDIATELY"
        echo "🌐 Server is starting at: http://127.0.0.1:$SERVER_PORT"
        echo "💡 Server may take up to 80 seconds to fully initialize"
        echo "📝 Check server status with: curl http://127.0.0.1:$SERVER_PORT/"
        echo ""
        exit 0
    else
        log_error "❌ Server restart failed."
        exit 1
    fi
}

# Run main function
main "$@"
