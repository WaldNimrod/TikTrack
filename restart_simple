#!/bin/bash

# TikTrack Simple Restart Script with Timeout Protection
# =====================================================
# 
# 🎯 Purpose: Simple, reliable server restart with guaranteed control return
# 🚀 Features: Timeout protection, background execution, guaranteed exit
# 📖 Documentation: documentation/server/RESTART_SCRIPT_GUIDE.md

set -e

# Configuration
SERVER_PORT=8080
SERVER_HOST="127.0.0.1"
MAX_EXECUTION_TIME=120  # 2 minutes maximum
HEALTH_CHECK_TIMEOUT=5  # 5 seconds per health check

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Timestamp
timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

# Logging
log_info() {
    echo -e "${BLUE}[$(timestamp)] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(timestamp)] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(timestamp)] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(timestamp)] ERROR:${NC} $1"
}

# Function to set cache environment
set_cache_mode() {
    local mode="$1"
    
    case $mode in
        development)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: DEVELOPMENT (10 seconds TTL)"
            ;;
        no-cache)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="true"
            log_info "Cache mode: NO-CACHE (disabled)"
            ;;
        production)
            export TIKTRACK_DEV_MODE="false"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: PRODUCTION (5 minutes TTL)"
            ;;
        preserve)
            log_info "Cache mode: PRESERVE (keeping current state)"
            ;;
        *)
            log_error "Invalid cache mode: $mode"
            exit 1
            ;;
    esac
}

# Function to stop server with timeout
stop_server() {
    log_info "🛑 Stopping server..."
    
    # Kill all Python processes running app.py or dev_server.py
    local processes=$(pgrep -f "\(python3\|Python\).*\(app\.py\|dev_server\.py\)" 2>/dev/null || true)
    if [ -n "$processes" ]; then
        log_info "Found server processes: $processes"
        pkill -f "\(python3\|Python\).*\(app\.py\|dev_server\.py\)" 2>/dev/null || true
        sleep 2
    fi
    
    # Kill processes using port
    if lsof -i :$SERVER_PORT > /dev/null 2>&1; then
        log_warning "Port $SERVER_PORT is still in use, killing processes..."
        lsof -ti :$SERVER_PORT | xargs kill -9 2>/dev/null || true
        sleep 1
    fi
    
    # Quick verification
    if curl -s --max-time 2 "http://$SERVER_HOST:$SERVER_PORT/" > /dev/null 2>&1; then
        log_warning "Server still responding, but continuing..."
    else
        log_success "Server stopped successfully"
    fi
}

# Function to start server
start_server() {
    log_info "🚀 Starting server..."
    
    # Make sure we're in the Backend directory
    if [ ! -f "Backend/dev_server.py" ]; then
        log_error "Backend/dev_server.py not found"
        return 1
    fi
    
    # Start server in background
    cd Backend
    
    # Start server with environment variables
    TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE" \
    TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED" \
    nohup python3 dev_server.py > /dev/null 2>&1 &
    
    local server_pid=$!
    cd ..
    
    log_info "Server process started with PID: $server_pid"
    return 0
}

# Function to check server health with timeout
check_server_health() {
    local max_attempts=12  # 12 attempts * 5 seconds = 60 seconds max
    local attempt=1
    
    log_info "⏳ Waiting for server to initialize..."
    
    while [ $attempt -le $max_attempts ]; do
        log_info "Health check attempt $attempt/$max_attempts..."
        
        # Check basic response
        if curl -s --max-time $HEALTH_CHECK_TIMEOUT "http://$SERVER_HOST:$SERVER_PORT/" > /dev/null 2>&1; then
            log_success "✅ Basic server response OK"
            
            # Check API health
            if curl -s --max-time $HEALTH_CHECK_TIMEOUT "http://$SERVER_HOST:$SERVER_PORT/api/health" > /dev/null 2>&1; then
                log_success "✅ API health OK"
                return 0
            else
                log_warning "API health check failed, but server is responding"
                return 0  # Server is up, API might be slow
            fi
        fi
        
        log_info "Server not ready yet, waiting 5 seconds..."
        sleep 5
        attempt=$((attempt + 1))
    done
    
    log_warning "⚠️ Server health check timeout after $max_attempts attempts"
    return 1
}

# Function to show help
show_help() {
    echo "🔄 TikTrack Simple Restart Script"
    echo "=================================="
    echo ""
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --cache-mode=MODE    Set cache mode"
    echo "                        MODE: development, no-cache, production, preserve"
    echo "  --help               Show this help"
    echo ""
    echo "Cache Modes:"
    echo "  development          Cache TTL: 10 seconds (fast development)"
    echo "  no-cache            Cache disabled (immediate updates)"
    echo "  production          Cache TTL: 5 minutes (performance)"
    echo "  preserve            Keep current cache state (default)"
    echo ""
    echo "Features:"
    echo "  - Timeout protection (2 minutes maximum)"
    echo "  - Background execution"
    echo "  - Guaranteed control return"
    echo "  - Simple health checks"
    echo ""
    echo "Examples:"
    echo "  $0                                    # Default restart with preserve cache"
    echo "  $0 --cache-mode=development          # Development cache mode"
    echo ""
}

# Main function with timeout protection
main() {
    local cache_mode="preserve"
    local start_time=$(date +%s)
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --cache-mode=*)
                cache_mode="${1#*=}"
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Header
    echo "🔄 TikTrack Simple Restart Script"
    echo "=================================="
    echo "📅 Started at: $(timestamp)"
    echo "🎯 Cache Mode: $cache_mode"
    echo "⏱️ Max Execution Time: ${MAX_EXECUTION_TIME}s"
    echo ""
    
    # Set cache mode
    set_cache_mode "$cache_mode"
    echo ""
    
    # Stop server
    stop_server
    echo ""
    
    # Start server
    if ! start_server; then
        log_error "Failed to start server"
        exit 1
    fi
    echo ""
    
    # Check server health with timeout
    if check_server_health; then
        # Calculate total time
        local end_time=$(date +%s)
        local total_time=$((end_time - start_time))
        
        echo ""
        log_success "🎉 Server restart completed successfully!"
        echo "📊 Summary:"
        echo "   - Total time: ${total_time} seconds"
        echo "   - Cache mode: $cache_mode"
        echo "   - Status: ✅ SUCCESS"
        echo "🌐 Server is available at: http://$SERVER_HOST:$SERVER_PORT"
        echo ""
        exit 0
    else
        # Calculate total time
        local end_time=$(date +%s)
        local total_time=$((end_time - start_time))
        
        echo ""
        log_warning "⚠️ Server restart completed with warnings"
        echo "📊 Summary:"
        echo "   - Total time: ${total_time} seconds"
        echo "   - Cache mode: $cache_mode"
        echo "   - Status: ⚠️ WARNING (server may still be starting)"
        echo "🌐 Try accessing: http://$SERVER_HOST:$SERVER_PORT"
        echo ""
        exit 0  # Exit with success even if health check failed
    fi
}

# Simple execution without timeout (macOS doesn't have timeout command)
main "$@"
