#!/bin/bash

# TikTrack Restart Script - Stages 1-3 Only
# ==========================================
# 
# 🎯 Purpose: Execute only stages 1-3 (Preparation, Stop, Start)
# ⚡ Features: No waiting, no health checks, instant return
# 📖 Based on: Analysis of problematic stage 4

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Logging
log_info() {
    echo -e "${BLUE}[$(date '+%H:%M:%S')] INFO:${NC} $1"
}

log_success() {
    echo -e "${GREEN}[$(date '+%H:%M:%S')] SUCCESS:${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[$(date '+%H:%M:%S')] WARNING:${NC} $1"
}

log_error() {
    echo -e "${RED}[$(date '+%H:%M:%S')] ERROR:${NC} $1"
}

# Stage 1: Preparation
stage_1_preparation() {
    log_info "=== STAGE 1: PREPARATION ==="
    
    # Check if Backend directory exists
    if [ ! -d "Backend" ]; then
        log_error "Backend directory not found"
        exit 1
    fi
    log_success "Backend directory found"
    
    # Set cache mode
    local mode="$1"
    case $mode in
        development)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: DEVELOPMENT"
            ;;
        no-cache)
            export TIKTRACK_DEV_MODE="true"
            export TIKTRACK_CACHE_DISABLED="true"
            log_info "Cache mode: NO-CACHE"
            ;;
        production)
            export TIKTRACK_DEV_MODE="false"
            export TIKTRACK_CACHE_DISABLED="false"
            log_info "Cache mode: PRODUCTION"
            ;;
        preserve)
            log_info "Cache mode: PRESERVE"
            ;;
        *)
            log_error "Invalid cache mode: $mode"
            exit 1
            ;;
    esac
    
    log_success "Stage 1 completed: Preparation"
}

# Stage 2: Stop
stage_2_stop() {
    log_info "=== STAGE 2: STOP ==="
    
    # Kill processes using port 8080
    if lsof -i :8080 >/dev/null 2>&1; then
        log_info "Found processes on port 8080, stopping..."
        lsof -ti :8080 | xargs kill -9 2>/dev/null || true
        sleep 1
        log_success "Port 8080 cleared"
    else
        log_info "No processes found on port 8080"
    fi
    
    # Kill Python processes
    local python_processes=$(ps aux | grep -E "(python|flask|dev_server)" | grep -v grep | awk '{print $2}')
    if [ -n "$python_processes" ]; then
        log_info "Found Python processes: $python_processes"
        echo "$python_processes" | xargs kill -9 2>/dev/null || true
        sleep 1
        log_success "Python processes stopped"
    else
        log_info "No Python processes found"
    fi
    
    log_success "Stage 2 completed: Stop"
}

# Stage 3: Start
stage_3_start() {
    log_info "=== STAGE 3: START ==="
    
    # Enter Backend directory
    cd Backend
    
    # Start server with environment variables
    TIKTRACK_DEV_MODE="$TIKTRACK_DEV_MODE" \
    TIKTRACK_CACHE_DISABLED="$TIKTRACK_CACHE_DISABLED" \
    nohup python3 dev_server.py > /dev/null 2>&1 &
    
    local server_pid=$!
    cd ..
    
    log_success "Server started with PID: $server_pid"
    log_info "Server is starting in background..."
    
    log_success "Stage 3 completed: Start"
}

# Main function
main() {
    local cache_mode="preserve"
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --cache-mode=*)
                cache_mode="${1#*=}"
                shift
                ;;
            *)
                log_warning "Unknown option: $1. Ignoring."
                shift
                ;;
        esac
    done
    
    echo "🔄 TikTrack Restart Script - Stages 1-3 Only"
    echo "============================================="
    echo "📅 Started at: $(date '+%H:%M:%S')"
    echo "🎯 Cache Mode: $cache_mode"
    echo "⚡ Approach: Stages 1-3 only (no waiting)"
    echo ""
    
    # Execute stages 1-3
    stage_1_preparation "$cache_mode"
    echo ""
    
    stage_2_stop
    echo ""
    
    stage_3_start
    echo ""
    
    # Immediate return - no stage 4 or 5
    log_success "🎉 Stages 1-3 completed successfully!"
    echo "📊 Summary:"
    echo "   - Stage 1: Preparation ✅"
    echo "   - Stage 2: Stop ✅"
    echo "   - Stage 3: Start ✅"
    echo "   - Stage 4: Wait ❌ (skipped)"
    echo "   - Stage 5: Finish ❌ (skipped)"
    echo "🌐 Server is starting at: http://127.0.0.1:8080"
    echo "💡 Server may take up to 80 seconds to fully initialize"
    echo "🚀 Control returned immediately!"
    echo ""
    
    exit 0
}

# Run main function
main "$@"
