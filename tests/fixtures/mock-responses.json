            },
            "localStorage": {
              "size": 2048,
              "count": 20,
              "hit_rate": 0.90
            },
            "indexedDB": {
              "size": 4096,
              "count": 30,
              "hit_rate": 0.95
            },
            "backend": {
              "size": 8192,
              "count": 40,
              "hit_rate": 0.98
            }
          }
        }
      }
    },
    "logs": {
      "send": {
