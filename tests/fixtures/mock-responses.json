      "clear": {
        "success": {
          "status": 200,
          "message": "Cache cleared successfully",
          "cleared_layers": ["memory", "localStorage", "indexedDB", "backend"]
        },
        "error": {
          "status": 500,
          "error": "Cache Clear Failed",
          "message": "Failed to clear cache"
        }
      },
      "stats": {
        "success": {
          "status": 200,
          "data": {
            "memory": {
              "size": 1024,
