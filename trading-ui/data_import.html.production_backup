        window.showModalSafe = async function(modalId, mode = 'add') {
            try {
                if (!window.ModalManagerV2) {
                    for (let i = 0; i < 20; i++) {
                        await new Promise(resolve => setTimeout(resolve, 100));
                        if (window.ModalManagerV2) {
                            break;
                        }
                    }
