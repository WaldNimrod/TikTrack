<!DOCTYPE html>
<!--
  ========================================
  דף ניטור Linter בזמן אמת - Linter Realtime Monitor
  ========================================
  
  דף זה מציג ניטור בזמן אמת של Linter
  כולל סטטיסטיקות, גרפים וניהול לוגים
  
  תכונות:
  - ניטור בזמן אמת של שגיאות Linter
  - גרפים אינטראקטיביים
  - ניהול לוגים
  - העתקת לוגים מפורטים
  - רענון אוטומטי
  
  ===== IMPORTANT DEVELOPMENT RULES =====
  
  CSS RULES:
  - Only external CSS files are used, following the system's CSS architecture
  - NO inline styles or styles within the page are allowed in this system
  - All styling must be defined in external stylesheets according to ITCSS methodology
  
  JAVASCRIPT RULES:
  - All functions are located in external files
  - NO functions are allowed within the page
  - All system functions use shared global functions located in dedicated files
  - Page-specific functions should be centralized only in the page's dedicated script file
  
  ======================================
  
  מחבר: Tik.track Development Team
  תאריך עדכון אחרון: 2025
  ========================================
-->
<html lang="he" dir="rtl">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS Files - אחרי Bootstrap כדי לדרוס אותו -->
    <!-- 🔄 MAJOR ARCHITECTURE CHANGE - September 2025: Individual <link> tags instead of @import -->
    <link rel="stylesheet" href="styles-new/01-settings/_variables.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/01-settings/_colors-dynamic.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/01-settings/_colors-semantic.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/01-settings/_spacing.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/01-settings/_typography.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/01-settings/_rtl-logical.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/03-generic/_reset.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/03-generic/_base.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/04-elements/_headings.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/04-elements/_links.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/04-elements/_forms-base.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/04-elements/_buttons-base.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/05-objects/_layout.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/05-objects/_grid.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/06-components/_buttons-advanced.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/06-components/_tables.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/06-components/_cards.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/06-components/_modals.css?v=v1.0.0">
    <link rel="stylesheet" href="styles-new/06-components/_notifications.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_navigation.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_forms-advanced.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_badges-status.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_entity-colors.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_info-summary.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_page-headers.css?v=20250916_03">
    <link rel="stylesheet" href="styles-new/06-components/_system-management.css?v=20250916_03">

    <!-- Header Styles -->
    <link rel="stylesheet" href="styles-new/header-styles.css?v=v38_fixed">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="linter-realtime-monitor-page">
    <!-- Unified Header Container -->
    <div id="unified-header"></div>

    <div class="background-wrapper">
    
    <!-- Page body - All content after header -->
    <div class="page-body">
      <!-- Linter Monitor area - top-Section -->
      <div class="top-section content-section" id="topSection" data-table-type="linter-realtime-monitor">
        <!-- Main header -->
        <div class="section-header">
          <div class="table-title">
            <img src="images/icons/development.svg" alt="ניטור Linter" class="table-icon">
            ניטור Linter בזמן אמת
          </div>
          <div class="table-actions">
            <button class="btn btn-outline-primary btn-sm" onclick="window.copyDetailedLog()" title="העתק לוג מפורט עם כל הנתונים והסטטוס">
              <i class="fas fa-copy"></i> העתק לוג מפורט
            </button>
            <button class="btn btn-outline-secondary btn-sm" onclick="window.toggleAutoRefresh()" title="הפעל/בטל רענון אוטומטי" id="autoRefreshBtn">
              <i class="fas fa-sync-alt"></i> רענון אוטומטי
            </button>
            <button class="filter-toggle-btn" onclick="window.toggleAllSections()" title="הצג/הסתר כל הסקשנים">
              <span class="filter-icon">▲</span>
            </button>
          </div>
        </div>

        <!-- Alert cards -->
        <div class="section-body">
          <active-alerts></active-alerts>

          <!-- Linter summary with improved design -->
          <div class="status-grid" id="summaryStats">
            <div class="status-item">
              <span class="label">סטטוס:</span>
              <span class="value">
                <span class="status-dot connected"></span>
                <strong id="overallStatus">בדיקה...</strong>
              </span>
            </div>
            <div class="status-item">
              <span class="label">קבצים נסרקו:</span>
              <span class="value"><strong id="totalFilesStats">0</strong></span>
            </div>
            <div class="status-item">
              <span class="label">שגיאות:</span>
              <span class="value"><strong id="totalErrorsStats">0</strong></span>
            </div>
            <div class="status-item">
              <span class="label">אזהרות:</span>
              <span class="value"><strong id="totalWarningsStats">0</strong></span>
            </div>
          </div>
        </div>
      </div> <!-- End top-section -->

      <!-- Main content -->
      <div class="main-content" data-section="linter-monitor" data-table-type="linter-realtime-monitor">

        <!-- Quality Chart Section -->
        <div class="content-section" id="chartSection" data-table-type="linter-realtime-monitor">
          <!-- Chart header -->
          <div class="section-header">
            <div class="table-title">
              <img src="images/icons/development.svg" alt="גרפים" class="section-icon">
              גרפי איכות קוד
            </div>
            <div class="table-actions">
              <button class="refresh-btn" onclick="window.updateChart && window.updateChart()" title="רענן גרף">
                <i class="fas fa-chart-line"></i> רענן גרף
              </button>
              <div class="action-separator"></div>
              <button class="filter-toggle-btn" onclick="window.toggleSection('chartSection')" title="הצג/הסתר אזור גרפים">
                <span class="filter-icon">▲</span>
              </button>
            </div>
          </div>
                <div class="stat-content">
                  <div class="stat-value" id="warningCount">0</div>
                  <div class="stat-label">אזהרות</div>
                  <div class="stat-change neutral" id="warningChange">+0</div>
                </div>
              </div>

              <div class="stat-item success">
                <div class="stat-icon">
                  <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-content">
                  <div class="stat-value" id="successCount">0</div>
                  <div class="stat-label">הצלחות</div>
                  <div class="stat-change neutral" id="successChange">+0</div>
                </div>
              </div>

              <div class="stat-item info">
                <div class="stat-icon">
                  <i class="fas fa-file-code"></i>
                </div>
                <div class="stat-content">
                  <div class="stat-value" id="filesScanned">0</div>
                  <div class="stat-label">קבצים נסרקו</div>
                  <div class="stat-change neutral" id="filesChange">+0</div>
                </div>
              </div>
            </div>
          </div>
        </div> <!-- End statistics section -->

        <!-- Chart Section -->
        <div class="content-section" id="chartSection" data-table-type="linter-realtime-monitor">
          <!-- Chart header -->
          <div class="section-header">
            <div class="table-title">
              <img src="images/icons/development.svg" alt="גרפים" class="section-icon">
              גרפי ניטור Linter
            </div>
            <div class="table-actions">
              <button class="refresh-btn" onclick="window.updateChart && window.updateChart()" title="רענן גרף">
                <i class="fas fa-chart-line"></i> רענן גרף
              </button>
              <div class="action-separator"></div>
              <button class="filter-toggle-btn" onclick="window.toggleSection('chartSection')" title="הצג/הסתר אזור גרפים">
                <span class="filter-icon">▲</span>
              </button>
            </div>
          </div>

          <!-- Chart body -->
          <div class="section-body">
            <div class="chart-container" style="width: 100%; height: 500px; margin: 0 auto;">
              <canvas id="linterChart" style="width: 100%; height: 100%; display: block;"></canvas>
            </div>
          </div>
        </div> <!-- End chart section -->

        <!-- Controls Section -->
        <div class="content-section" id="controlsSection" data-table-type="linter-realtime-monitor">
          <!-- Controls header -->
          <div class="section-header">
            <div class="table-title">
              <img src="images/icons/development.svg" alt="הגדרות" class="section-icon">
              הגדרות ניטור
            </div>
            <div class="table-actions">
              <button class="refresh-btn" onclick="window.resetSettings && window.resetSettings()" title="איפוס הגדרות">
                <i class="fas fa-undo"></i> איפוס
              </button>
              <div class="action-separator"></div>
              <button class="filter-toggle-btn" onclick="window.toggleSection('controlsSection')" title="הצג/הסתר אזור הגדרות">
                <span class="filter-icon">▲</span>
              </button>
            </div>
          </div>

          <!-- Controls body -->
          <div class="section-body">
            <div class="controls-grid">
              <div class="control-group">
                <label class="control-label">תדירות סריקה (שניות)</label>
                <input type="number" class="control-input" id="scanInterval" value="5" min="1" max="60">
              </div>
              <div class="control-group">
                <label class="control-label">רמת לוג</label>
                <select class="control-select" id="logLevel">
                  <option value="error">שגיאות בלבד</option>
                  <option value="warning" selected>אזהרות ושגיאות</option>
                  <option value="info">כל ההודעות</option>
                </select>
              </div>
              <div class="control-group">
                <label class="control-label">תיקיות לסריקה</label>
                <input type="text" class="control-input" id="scanPaths" value="trading-ui/">
              </div>
            </div>
            <div class="controls-actions" style="display: flex; gap: 10px; flex-wrap: wrap;">
              <button class="btn btn-primary" id="startMonitoring" onclick="window.startMonitoring && window.startMonitoring()">
                <i class="bi bi-play-fill"></i> התחל ניטור
              </button>
              <button class="btn btn-secondary" id="stopMonitoring" disabled onclick="window.stopMonitoring && window.stopMonitoring()">
                <i class="bi bi-stop-fill"></i> עצור ניטור
              </button>
              <button class="btn btn-success" id="clearLogs" onclick="window.clearLogs && window.clearLogs()">
                <i class="bi bi-trash"></i> נקה לוגים
              </button>
              <button class="btn btn-danger" id="exportLogs" onclick="window.exportLogs && window.exportLogs()">
                <i class="bi bi-download"></i> ייצא לוגים
              </button>
            </div>
            
            <!-- Fix Actions -->
            <div class="fix-actions">
              <h5>פעולות תיקון</h5>
              <div class="fix-buttons" style="display: flex; gap: 10px; flex-wrap: wrap;">
                <button class="btn btn-success" onclick="window.fixAllIssues()" title="תקן את כל הבעיות הניתנות לתיקון">
                  <i class="fas fa-magic"></i> תיקון אוטומטי לכל הבעיות
                </button>
                <button class="btn btn-warning" onclick="window.fixAllErrors()" title="תקן רק שגיאות">
                  <i class="fas fa-exclamation-triangle"></i> תיקון שגיאות בלבד
                </button>
                <button class="btn btn-info" onclick="window.fixAllWarnings()" title="תקן רק אזהרות">
                  <i class="fas fa-exclamation-circle"></i> תיקון אזהרות בלבד
                </button>
                <button class="btn btn-secondary" onclick="window.ignoreAllIssues()" title="התעלם מכל הבעיות">
                  <i class="fas fa-eye-slash"></i> התעלם מהכל
                </button>
              </div>
            </div>
          </div>
        </div> <!-- End controls section -->

        <!-- Logs Section -->
        <div class="content-section" id="logsSection" data-table-type="linter-realtime-monitor">
          <!-- Logs header -->
          <div class="section-header">
            <div class="table-title">
              <img src="images/icons/development.svg" alt="לוגים" class="section-icon">
              לוגי Linter
            </div>
            <div class="table-count" id="logsCount">טוען...</div>
            <div class="table-actions">
              <button class="refresh-btn" onclick="window.loadIssues && window.loadIssues()" title="רענן לוגים">
                <i class="fas fa-list"></i> רענן לוגים
              </button>
              <div class="action-separator"></div>
              <button class="filter-toggle-btn" onclick="window.toggleSection('logsSection')" title="הצג/הסתר אזור לוגים">
                <span class="filter-icon">▲</span>
              </button>
            </div>
          </div>

          <!-- Logs body -->
          <div class="section-body">
            <!-- Logs Filters -->
            <div class="logs-filters" style="display: flex; gap: 10px; margin-bottom: 15px; flex-wrap: wrap; align-items: center;">
              <div class="filter-group">
                <label style="margin-right: 8px; font-weight: 500;">סינון:</label>
                <select id="logLevelFilter" style="padding: 4px 8px; border: 1px solid #ddd; border-radius: 4px;">
                  <option value="all">הכל</option>
                  <option value="error">שגיאות</option>
                  <option value="warning">אזהרות</option>
                  <option value="info">מידע</option>
                </select>
              </div>
              <div class="filter-group">
                <input type="text" id="logSearchFilter" placeholder="חיפוש בלוגים..." style="padding: 4px 8px; border: 1px solid #ddd; border-radius: 4px; min-width: 200px;">
              </div>
              <div class="filter-group">
                <button id="clearFiltersBtn" class="btn btn-sm btn-outline-secondary" style="padding: 4px 12px;" onclick="window.clearFiltersBtn && window.clearFiltersBtn()">
                  <i class="fas fa-times"></i> נקה סינונים
                </button>
              </div>
            </div>

            <div class="logs-container" id="logsContainer">
              <div class="log-entry">
                <div class="log-header">
                  <span class="log-timestamp">[${new Date().toLocaleTimeString('he-IL')}]</span>
                  <span class="log-level info">[INFO]</span>
                </div>
                <div class="log-message">מערכת ניטור Linter אותחלה</div>
              </div>
            </div>
          </div>
        </div> <!-- End logs section -->

      </div> <!-- End main-content -->
    </div> <!-- End page-body -->
  </div> <!-- End background-wrapper -->

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chart.js for graphs -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1"></script>

    <!-- Scripts -->
    <script src="scripts/header-system.js?v=v34_fixes"></script>
    <script src="scripts/color-scheme-system.js"></script>
    <script src="scripts/preferences.js"></script>
    <script src="scripts/ui-utils.js"></script>
    <script src="scripts/tables.js"></script>
    <script src="scripts/translation-utils.js"></script>
    <script src="scripts/data-utils.js"></script>
    <script src="scripts/linked-items.js"></script>
    <script src="scripts/page-utils.js"></script>
    <script src="scripts/central-refresh-system.js"></script>
    <script src="scripts/notification-system.js"></script>
    <script src="scripts/main.js"></script>
    <script src="scripts/linter-realtime-monitor.js?v=20250916_final"></script>
</body>
</html>
