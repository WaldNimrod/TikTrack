    log.push(`  - גודל מטמון: ${backendCacheSize}`);
    log.push(`  - מספר ערכים: ${backendCacheEntries}`);
    log.push(`  - זיכרון בשימוש: ${backendCacheMemory}`);
    
    // Preferences Cache System (Frontend)
