• ${(cacheData.analytics?.estimated_memory_mb || (cacheData.status?.size ? cacheData.status.size / (1024 * 1024) : 0)) > 80 ? 'שימוש בזיכרון גבוה' : 'שימוש בזיכרון תקין'}
