# TikTrack Phoenix - Environment Variables Template
# =================================================
# Copy this file to .env.development or .env.production
# All variables MUST have VITE_ prefix (Vite requirement)

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Application Info
VITE_APP_NAME=TikTrack Phoenix
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development
