# TikTrack Phoenix - Production Environment Variables
# ====================================================
# All variables MUST have VITE_ prefix (Vite requirement)
# Access in code: import.meta.env.VITE_API_BASE_URL

# API Configuration
VITE_API_BASE_URL=https://api.tiktrack.com/api/v1

# Application Info
VITE_APP_NAME=TikTrack Phoenix
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=production
