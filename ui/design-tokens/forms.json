{
  "version": "1.0.0",
  "metadata": {
    "created": "2026-01-31",
    "team": "Team 40 (UI Assets)",
    "session": "SESSION_01",
    "source": "design-tokens/auth.json",
    "compliance": "All styles based on Design Tokens - Zero Hardcoded Values"
  },
  "input": {
    "base": {
      "backgroundColor": "var(--color-1)",
      "borderColor": "var(--color-20)",
      "borderWidth": "1px",
      "borderStyle": "solid",
      "borderRadius": "var(--radius-md)",
      "padding": "var(--spacing-3) var(--spacing-4)",
      "fontSize": "var(--font-size-base)",
      "fontFamily": "var(--font-primary)",
      "color": "var(--text-primary)",
      "lineHeight": "var(--line-height-normal)",
      "transition": "all 0.2s ease-in-out"
    },
    "states": {
      "default": {
        "borderColor": "var(--color-20)",
        "backgroundColor": "var(--color-1)"
      },
      "focus": {
        "borderColor": "var(--color-primary)",
        "backgroundColor": "var(--color-1)",
        "boxShadow": "0 0 0 3px rgba(38, 186, 172, 0.1)",
        "outline": "none"
      },
      "hover": {
        "borderColor": "var(--color-30)",
        "backgroundColor": "var(--color-1)"
      },
      "disabled": {
        "backgroundColor": "var(--color-5)",
        "borderColor": "var(--color-20)",
        "color": "var(--text-tertiary)",
        "cursor": "not-allowed",
        "opacity": "0.6"
      },
      "error": {
        "borderColor": "var(--color-error)",
        "backgroundColor": "var(--color-1)",
        "boxShadow": "0 0 0 3px rgba(239, 68, 68, 0.1)"
      },
      "success": {
        "borderColor": "var(--color-success)",
        "backgroundColor": "var(--color-1)",
        "boxShadow": "0 0 0 3px rgba(16, 185, 129, 0.1)"
      }
    },
    "sizes": {
      "sm": {
        "padding": "var(--spacing-2) var(--spacing-3)",
        "fontSize": "var(--font-size-sm)",
        "height": "32px"
      },
      "md": {
        "padding": "var(--spacing-3) var(--spacing-4)",
        "fontSize": "var(--font-size-base)",
        "height": "40px"
      },
      "lg": {
        "padding": "var(--spacing-4) var(--spacing-5)",
        "fontSize": "var(--font-size-lg)",
        "height": "48px"
      }
    },
    "placeholder": {
      "color": "var(--text-tertiary)",
      "opacity": "0.7"
    }
  },
  "button": {
    "base": {
      "fontFamily": "var(--font-primary)",
      "fontWeight": "var(--font-weight-semibold)",
      "borderRadius": "var(--radius-md)",
      "border": "none",
      "cursor": "pointer",
      "transition": "all 0.2s ease-in-out",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center",
      "gap": "var(--spacing-2)",
      "lineHeight": "var(--line-height-normal)"
    },
    "variants": {
      "primary": {
        "backgroundColor": "var(--color-primary)",
        "color": "var(--text-inverse)",
        "boxShadow": "var(--shadow-sm)",
        "hover": {
          "backgroundColor": "var(--color-primary-dark)",
          "boxShadow": "var(--shadow-md)",
          "transform": "translateY(-1px)"
        },
        "active": {
          "backgroundColor": "var(--color-primary-darker)",
          "transform": "translateY(0)"
        },
        "disabled": {
          "backgroundColor": "var(--color-30)",
          "color": "var(--text-tertiary)",
          "cursor": "not-allowed",
          "opacity": "0.6",
          "boxShadow": "none"
        }
      },
      "secondary": {
        "backgroundColor": "var(--color-secondary)",
        "color": "var(--text-inverse)",
        "boxShadow": "var(--shadow-sm)",
        "hover": {
          "backgroundColor": "var(--color-secondary-dark)",
          "boxShadow": "var(--shadow-md)",
          "transform": "translateY(-1px)"
        },
        "active": {
          "backgroundColor": "var(--color-secondary-darker)",
          "transform": "translateY(0)"
        },
        "disabled": {
          "backgroundColor": "var(--color-30)",
          "color": "var(--text-tertiary)",
          "cursor": "not-allowed",
          "opacity": "0.6",
          "boxShadow": "none"
        }
      },
      "outline": {
        "backgroundColor": "transparent",
        "color": "var(--color-primary)",
        "border": "1px solid var(--color-primary)",
        "hover": {
          "backgroundColor": "var(--color-primary)",
          "color": "var(--text-inverse)"
        },
        "active": {
          "backgroundColor": "var(--color-primary-dark)",
          "color": "var(--text-inverse)"
        },
        "disabled": {
          "borderColor": "var(--color-20)",
          "color": "var(--text-tertiary)",
          "cursor": "not-allowed",
          "opacity": "0.6"
        }
      },
      "ghost": {
        "backgroundColor": "transparent",
        "color": "var(--color-primary)",
        "hover": {
          "backgroundColor": "var(--color-5)",
          "color": "var(--color-primary-dark)"
        },
        "active": {
          "backgroundColor": "var(--color-10)"
        },
        "disabled": {
          "color": "var(--text-tertiary)",
          "cursor": "not-allowed",
          "opacity": "0.6"
        }
      },
      "danger": {
        "backgroundColor": "var(--color-error)",
        "color": "var(--text-inverse)",
        "boxShadow": "var(--shadow-sm)",
        "hover": {
          "backgroundColor": "var(--color-error-dark)",
          "boxShadow": "var(--shadow-md)",
          "transform": "translateY(-1px)"
        },
        "active": {
          "backgroundColor": "var(--color-error-darker)",
          "transform": "translateY(0)"
        },
        "disabled": {
          "backgroundColor": "var(--color-30)",
          "color": "var(--text-tertiary)",
          "cursor": "not-allowed",
          "opacity": "0.6",
          "boxShadow": "none"
        }
      }
    },
    "sizes": {
      "sm": {
        "padding": "var(--spacing-2) var(--spacing-3)",
        "fontSize": "var(--font-size-sm)",
        "height": "32px",
        "minWidth": "80px"
      },
      "md": {
        "padding": "var(--spacing-3) var(--spacing-5)",
        "fontSize": "var(--font-size-base)",
        "height": "40px",
        "minWidth": "100px"
      },
      "lg": {
        "padding": "var(--spacing-4) var(--spacing-6)",
        "fontSize": "var(--font-size-lg)",
        "height": "48px",
        "minWidth": "120px"
      }
    },
    "fullWidth": {
      "width": "100%"
    }
  },
  "validation": {
    "error": {
      "color": "var(--color-error)",
      "fontSize": "var(--font-size-sm)",
      "marginTop": "var(--spacing-1)",
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--spacing-1)"
    },
    "success": {
      "color": "var(--color-success)",
      "fontSize": "var(--font-size-sm)",
      "marginTop": "var(--spacing-1)",
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--spacing-1)"
    },
    "warning": {
      "color": "var(--color-warning)",
      "fontSize": "var(--font-size-sm)",
      "marginTop": "var(--spacing-1)",
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--spacing-1)"
    },
    "helper": {
      "color": "var(--text-secondary)",
      "fontSize": "var(--font-size-xs)",
      "marginTop": "var(--spacing-1)"
    }
  },
  "label": {
    "base": {
      "display": "block",
      "fontSize": "var(--font-size-sm)",
      "fontWeight": "var(--font-weight-semibold)",
      "color": "var(--text-primary)",
      "marginBottom": "var(--spacing-2)",
      "lineHeight": "var(--line-height-normal)"
    },
    "required": {
      "color": "var(--color-error)",
      "marginLeft": "var(--spacing-1)"
    },
    "optional": {
      "color": "var(--text-secondary)",
      "fontSize": "var(--font-size-xs)",
      "fontWeight": "var(--font-weight-normal)",
      "marginLeft": "var(--spacing-1)"
    }
  },
  "formGroup": {
    "marginBottom": "var(--spacing-5)",
    "lastChild": {
      "marginBottom": "0"
    }
  },
  "formSection": {
    "padding": "var(--spacing-6)",
    "backgroundColor": "var(--color-1)",
    "borderRadius": "var(--radius-lg)",
    "border": "1px solid var(--color-20)",
    "marginBottom": "var(--spacing-6)"
  }
}
